<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Airconi Aircon Trading</title>


    <link rel="icon" type="image/png" href="~/assets/favicon.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ARCon_Capstone_2.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ecommerce-chat.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons"
          rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://cdn.tailwindcss.com"></script>
    @RenderSection("Styles", required: false)
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light border-bottom box-shadow bg-white">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse d-sm-inline-flex justify-content-between collapse">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="About" asp-fragment="bottom-note">Contact</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index" asp-fragment="services">Services</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Search">Shop</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="top-bar d-flex align-items-center">
        <!-- Logo -->
        <div class="nav-item me-4">
            <a class="nav-link p-0" asp-controller="Home" asp-action="Index">
                <img src="~/ImageSources/Logo/aircon.PNG" alt="Logo" class="logo-img">
            </a>
        </div>

        <!-- Search -->
        <form class="search-form" asp-controller="Home" asp-action="Search" method="get">
            <input class="form-control search-input" type="search" name="query" placeholder="Search" />
            <button class="search-btn" type="submit">🔍</button>
        </form>




        <!-- Notification, Cart, & Login -->
        <div class="d-flex align-items-center ms-3 gap-3">

            <!--Notifications are only available when logged in-->
            @{
                var userId = Context.Session.GetInt32("UserId");
                var userType = Context.Session.GetString("UserType");
            }

            @if (userId != null && userType == "CUSTOMER")
            {
                <!-- 🔔 Notifications -->
                <a class="nav-link position-relative"
                   href="#"
                   data-bs-toggle="modal"
                   data-bs-target="#notificationModal"
                   id="notificationButton">
                    🔔
                    <span id="notificationCount"
                          class="position-absolute start-100 translate-middle badge rounded-pill bg-danger top-0"
                          style="display:none;">
                        0
                    </span>
                </a>
            }


            <!-- 🛒 Cart -->
            <a class="nav-link position-relative"
               asp-area="Shop"
               asp-controller="Cart"
               asp-action="MyCart">
                <i class="bi bi-cart-fill cart-icon" id="cart-index"></i>
            </a>

            <!--This will check if logged in or not!-->
            @{
                var firstName = Context.Session.GetString("CustomerFirstName");
            }

            @if (userType == "CUSTOMER" && !string.IsNullOrEmpty(firstName))
            {
                <!-- 👤 Customer Dropdown -->
                <div class="dropdown">
                    <a class="nav-link dropdown-toggle d-flex align-items-center"
                       href="#"
                       role="button"
                       data-bs-toggle="dropdown"
                       aria-expanded="false">
                        <i class="bi bi-person-circle me-1"></i> @firstName
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item"
                               asp-area="Shop"
                               asp-controller="Profile"
                               asp-action="MyProfile">
                                My Profile
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item"
                               asp-area="Shop"
                               asp-controller="Orders"
                               asp-action="MyPurchases">
                                My Purchases
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item"
                               asp-area="Shop"
                               asp-controller="Orders"
                               asp-action="MyServices">
                                My Services
                            </a>
                        </li>

                        <li><hr class="dropdown-divider"></li>

                        <li>
                            <a class="dropdown-item"
                               asp-area=""
                               asp-controller="Auth"
                               asp-action="Logout">
                                Logout
                            </a>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <!-- 🔐 Login -->
                <a class="nav-link"
                   asp-area="Shop"
                   asp-controller="Home"
                   asp-action="Login">
                    Login
                </a>
            }

        </div>

    </div>












    <!-- Notification Modal -->
    <div class="modal fade" id="notificationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-md">
            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header">
                    <h5 class="modal-title">Notifications</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body p-0">
                    <!-- Empty state (show when no notifications) -->
                <div class="text-muted py-4 text-center">
                    No notifications yet
                </div>

                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <a href="#" class="btn btn-primary">View all</a>
                </div>

            </div>
        </div>
    </div>



    <!-- Cart Modal -->
    <div id="cartModal" class="cart-modal"> 
        <div class="cart-modal-content">
            <span class="cart-close">&times;</span>
            <h2>Your Cart</h2>

            <div id="cartItems">
                <p>Your cart is empty.</p>
            </div>

            <div class="cart-footer">
                <p>Total: <span id="cartTotal">₱0</span></p>
                <div class="button-group">
                    <a class="btn btn-primary" asp-controller="Cart" asp-action="CartIndex">View Cart</a>
                    <a class="btn btn-secondary" asp-controller="Cart" asp-action="Checkout">Checkout</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Chat -->

    <div id="chatFloatingBtn">
            <img id="chat_logo" src="~/ImageSources/Logo/chat-logo.gif" alt="Chat Logo" />
        <span id="chatBadge" class="chat-badge" style="display:none;">1</span>
    </div>

    <div id="chatSidebar" class="chat-sidebar">
        <div class="chat-header">
            <div>
                <strong>Customer Support</strong><br>
                <small>We’re here to help</small>
            </div>
            <span onclick="closeChatSidebar()">✕</span>
        </div>

        <div class="chat-body" id="chatMessages">
            <div class="chat-row received">
                <div class="chat-bubble">
                    Hello! How can we help you today?
                    <div class="chat-time">10:30 AM</div>
                </div>
            </div>

            <div class="chat-row sent">
                <div class="chat-bubble">
                    I need help with my order.
                    <div class="chat-time">10:31 AM</div>
                </div>

            </div>
        </div>

        <div class="chat-footer">
            <textarea id="chatInput" placeholder="Type a message..."></textarea>
            <button onclick="sendCustomerMessage()">Send</button>
        </div>
    </div>


    <!-- Loading Overlay -->
    <div id="loadingOverlay">
        <div class="spinner-wrapper">
            <div class="spinner-ring"></div>
            <img src="~/ImageSources/Logo/aircon.PNG" alt="Loading..." class="logo-center" />
        </div>
    </div>


    <!-- Toast container -->
    <div id="toastContainer" class="toast-container position-fixed bottom-0 end-0 p-3"></div>
        <div class="container-fluid p-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - ARCon_Capstone_2 -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>



  
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        window.chatUserId = '@(Context.Session.GetInt32("UserId") ?? 0)';
        window.chatUserType = '@(Context.Session.GetString("UserType") ?? "")';


        window.addEventListener("load", function () {
            var loader = document.getElementById("loadingOverlay");
            if (loader) {
                loader.style.display = "none";
            }

            // to show
            // document.getElementById("loadingOverlay").style.display = "flex";
        });

        window.addEventListener("pageshow", function (event) {
            if (event.persisted || performance.getEntriesByType("navigation")[0]?.type === "back_forward") {
                window.location.reload();
            }
        });
    </script>
    <script src="~/js/customer-chat.js" asp-append-version="true"></script>

</body>
</html>



