<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ARCon_Capstone_2</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ARCon_Capstone_2.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Index.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index" asp-fragment="services">Services</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Search">Shop</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="top-bar d-flex align-items-center">
        <!-- Logo -->
        <div class="nav-item me-4">
            <a class="nav-link p-0" asp-controller="Home" asp-action="Index">
                <img src="~/ImageSources/Logo/aircon.PNG" alt="Logo" class="logo-img">
            </a>
        </div>

        <!-- Search -->
        <form class="search-form" asp-controller="Home" asp-action="Search" method="get">
            <input class="form-control search-input" type="search" name="query" placeholder="Search" />
            <button class="search-btn" type="submit">🔍</button>
        </form>

        <!-- Notification, Cart, & Login -->
        <div class="d-flex gap-3 ms-3">
            <a class="nav-link position-relative" href="#" data-bs-toggle="modal" data-bs-target="#notificationModal" id="notificationButton">
                🔔
                <span id="notificationCount"
                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                      style="display:none;">
                    0
                </span>
            </a>

            <a class="nav-link position-relative" href="#" id="cartButton">
                🛒
                <span id="cartCount"
                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                      style="display:none;">
                    0
                </span>
            </a>

            <a class="nav-link" asp-controller="Home" asp-action="Login">Login</a>
        </div>
    </div>

    <!-- Notification Modal -->
    <div class="modal fade" id="notificationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-md">
            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header">
                    <h5 class="modal-title">Notifications</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body p-0">
                    <!-- Empty state (show when no notifications) -->
                <div class="text-center text-muted py-4">
                    No notifications yet
                </div>

                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <a href="#" class="btn btn-primary">View all</a>
                </div>

            </div>
        </div>
    </div>


    <!-- Cart Modal -->
    <div id="cartModal" class="cart-modal"> 
        <div class="cart-modal-content">
            <span class="cart-close">&times;</span>
            <h2>Your Cart</h2>

            <div id="cartItems">
                <p>Your cart is empty.</p>
            </div>

            <div class="cart-footer">
                <p>Total: <span id="cartTotal">₱0</span></p>
                <div class="button-group">
                    <a class="btn btn-primary" asp-controller="Cart" asp-action="CartIndex">View Cart</a>
                    <a class="btn btn-secondary" asp-controller="Cart" asp-action="Checkout">Checkout</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast container -->
    <div id="toastContainer" class="toast-container position-fixed bottom-0 end-0 p-3"></div>

    <div class="container-fluid p-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - ARCon_Capstone_2 -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/View-js/Index.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

