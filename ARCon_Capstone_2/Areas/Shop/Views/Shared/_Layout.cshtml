<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Airconi Aircon Trading</title>


    <link rel="icon" type="image/png" href="~/assets/favicon.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ARCon_Capstone_2.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ecommerce-chat.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons"
          rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    @* <script src="https://cdn.tailwindcss.com"></script> *@
    @RenderSection("Styles", required: false)
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light border-bottom box-shadow bg-white">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse d-sm-inline-flex justify-content-between collapse">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" id="navbar-text" asp-controller="Home" asp-action="Index" asp-fragment="faq-section">FAQ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" id="navbar-text" asp-controller="Home" asp-action="Index" asp-fragment="contact-section">Contact</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" id="navbar-text" asp-controller="Home" asp-action="Index" asp-fragment="services">Services</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" id="navbar-text" asp-controller="Home" asp-action="Search">Shop</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="top-bar d-flex align-items-center">
        <!-- Logo -->
        <div class="nav-item me-4">
            <a class="nav-link p-0" asp-controller="Home" asp-action="Index">
                <img src="~/ImageSources/Logo/aircon.PNG" alt="Logo" class="logo-img">
            </a>
        </div>

        <!-- Search -->
        <form class="search-form"
              method="get"
              action="/Shop/Home/Search">

            <input class="form-control search-input"
                   type="search"
                   id="globalSearchInput"
                   name="search"
                   placeholder="Search products..." />

            <button class="search-btn"
                    type="submit">

                🔍

            </button>

        </form>




        <!-- Notification, Cart, & Login -->
        <div class="d-flex align-items-center ms-3 gap-3">

            <!--Notifications are only available when logged in-->
            @{
                var userId = Context.Session.GetInt32("UserId");
                var userType = Context.Session.GetString("UserType");
            }

            @if (userId != null && userType == "CUSTOMER")
            {
                <a class="nav-link position-relative"
                   href="#"
                   data-bs-toggle="modal"
                   data-bs-target="#notificationModal"
                   id="notificationButton">

                    <i class="bi bi-bell-fill fs-5"></i>

                    <span id="notificationCount"
                          class="badge bg-danger position-absolute"
                          style="
                        top:-5px;
                        right:-10px;
                        display:none;
                    ">
                        0
                    </span>

                </a>
            }


            <!-- 🛒 Cart -->
            <a class="nav-link position-relative"
               asp-area="Shop"
               asp-controller="Cart"
               asp-action="MyCart">
                <i class="bi bi-cart-fill cart-icon" id="cart-index"></i>
            </a>

            <!--This will check if logged in or not!-->
            @{
                var firstName = Context.Session.GetString("CustomerFirstName");
            }

            @if (userType == "CUSTOMER" && !string.IsNullOrEmpty(firstName))
            {
                <!-- 👤 Customer Dropdown -->
                <div class="dropdown">
                    <a class="nav-link dropdown-toggle d-flex align-items-center"
                       href="#"
                       role="button"
                       data-bs-toggle="dropdown"
                       aria-expanded="false">
                        <i class="bi bi-person-circle me-1"></i> @firstName
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>

                            <a class="dropdown-item"
                               href="#"
                               id="openProfileModal">

                                My Profile

                            </a>

                        </li>

                        <li>
                            <a class="dropdown-item"
                               asp-area="Shop"
                               asp-controller="Orders"
                               asp-action="MyPurchases">
                                My Purchases
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item"
                               asp-area="Shop"
                               asp-controller="Orders"
                               asp-action="MyServices">
                                My Services
                            </a>
                        </li>

                        <li><hr class="dropdown-divider"></li>

                        <li>
                            <a class="dropdown-item"
                               asp-area=""
                               asp-controller="Auth"
                               asp-action="Logout">
                                Logout
                            </a>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <!-- 🔐 Login -->
                <a class="nav-link" id="loginTxt"
                   asp-area="Shop"
                   asp-controller="Home"
                   asp-action="Login">
                    Login
                </a>
            }

        </div>

    </div>




    <!-- Notification Modal -->
    <div class="modal fade"
         id="notificationModal"
         tabindex="-1"
         aria-hidden="true">

        <div class="modal-dialog modal-dialog-scrollable notification-modal">

            <div class="modal-content notification-content">

                <!-- Header -->
                <div class="modal-header notification-header">

                    <div>

                        <h5 class="modal-title mb-0">
                            Notifications
                        </h5>

                        <small class="text-muted">
                            Recent updates from AIRCONI
                        </small>

                    </div>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>

                </div>

                <!-- Body -->
                <div class="modal-body p-0">

                    <div id="notificationContainer">

                        <div class="notification-empty">

                            <i class="bi bi-bell-slash"></i>

                            <div>
                                No notifications yet
                            </div>

                        </div>

                    </div>

                </div>

                <!-- Footer -->
                <div class="modal-footer">

                    <button class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">

                        Close

                    </button>

                    <a href="#"
                       class="btn btn-primary">

                        View All

                    </a>

                </div>

            </div>

        </div>

    </div>



    <!-- Cart Modal -->
    <div id="cartModal" class="cart-modal"> 
        <div class="cart-modal-content">
            <span class="cart-close">&times;</span>
            <h2>Your Cart</h2>

            <div id="cartItems">
                <p>Your cart is empty.</p>
            </div>

            <div class="cart-footer">
                <p>Total: <span id="cartTotal">₱0</span></p>
                <div class="button-group">
                    <a class="btn btn-primary" asp-controller="Cart" asp-action="CartIndex">View Cart</a>
                    <a class="btn btn-secondary" asp-controller="Cart" asp-action="Checkout">Checkout</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Chat -->

    <div id="chatFloatingBtn">
            <img id="chat_logo" src="~/ImageSources/Logo/chat-logo.gif" alt="Chat Logo" />
        <span id="chatBadge" class="chat-badge" style="display:none;">1</span>
    </div>

    <div id="chatSidebar" class="chat-sidebar">
        <div class="chat-header">
            <div>
                <strong>Customer Support</strong><br>
                <small>We’re here to help</small>
            </div>
            <span onclick="closeChatSidebar()">✕</span>
        </div>

        <div class="chat-body" id="chatMessages">
            <div class="chat-row received">
                <div class="chat-bubble">
                    Hello! How can we help you today?
                    <div class="chat-time">10:30 AM</div>
                </div>
            </div>

            <div class="chat-row sent">
                <div class="chat-bubble">
                    I need help with my order.
                    <div class="chat-time">10:31 AM</div>
                </div>

            </div>
        </div>

        <div class="chat-footer">
            <textarea id="chatInput" placeholder="Type a message..."></textarea>
            <button onclick="sendCustomerMessage()">Send</button>
        </div>
    </div>


    <!-- Loading Overlay -->
    <div id="loadingOverlay">
        <div class="spinner-wrapper">
            <div class="spinner-ring"></div>
            <img src="~/ImageSources/Logo/aircon.PNG" alt="Loading..." class="logo-center" />
        </div>
    </div>


    <!-- Toast container -->
    <div id="toastContainer" class="toast-container position-fixed bottom-0 end-0 p-3"></div>
        <div class="container-fluid p-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - ARCon_Capstone_2 -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>



  
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        window.chatUserId = '@(Context.Session.GetInt32("UserId") ?? 0)';
        window.chatUserType = '@(Context.Session.GetString("UserType") ?? "")';


        window.addEventListener("load", function () {
            var loader = document.getElementById("loadingOverlay");
            if (loader) {
                loader.style.display = "none";
            }

            // to show
            // document.getElementById("loadingOverlay").style.display = "flex";
        });

        window.addEventListener("pageshow", function (event) {
            if (event.persisted || performance.getEntriesByType("navigation")[0]?.type === "back_forward") {
                window.location.reload();
            }
        });
    </script>
    <script src="~/js/customer-chat.js" asp-append-version="true"></script>
   
</body>
</html>






<!-- ===================================== -->
<!-- AIRCONI PROFILE MODAL -->
<!-- ===================================== -->

<div class="modal fade"
     id="profileModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog
                modal-xl
                modal-dialog-scrollable
                airconi-profile-modal">

        <div class="modal-content airconi-profile-content">

            <!-- HEADER -->

            <div class="modal-header airconi-profile-header">

                <div>

                    <h4 class="mb-0">

                        My Profile

                    </h4>

                    <small>

                        Manage your account information,
                        password, and addresses.

                    </small>

                </div>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <!-- BODY -->

            <div class="modal-body airconi-profile-body">

                <div class="profile-layout">

                    <!-- ===================================== -->
                    <!-- LEFT COLUMN -->
                    <!-- ===================================== -->

                    <div class="profile-left-column">

                        <!-- PERSONAL INFO -->

                        <div class="profile-section-card">

                            <div class="section-header">

                                <h5>

                                    Personal Information

                                </h5>

                                <button class="btn btn-primary"
                                        id="saveProfileBtn">

                                    Save Profile

                                </button>

                            </div>

                            <div class="profile-grid">

                                <div>

                                    <label>
                                        First Name
                                    </label>

                                    <input type="text"
                                           class="form-control"
                                           id="profileFirstName"
                                           readonly>

                                </div>

                                <div>

                                    <label>
                                        Middle Name
                                    </label>

                                    <input type="text"
                                           class="form-control"
                                           id="profileMiddleName"
                                           readonly>

                                </div>

                                <div>

                                    <label>
                                        Last Name
                                    </label>

                                    <input type="text"
                                           class="form-control"
                                           id="profileLastName"
                                           readonly>

                                </div>

                                <div>

                                    <label>
                                        * Email Address
                                    </label>

                                    <input type="email"
                                           class="form-control"
                                           id="profileEmail">

                                </div>

                                <div>

                                    <label>
                                        * Contact Number
                                    </label>

                                    <input type="text"
                                           class="form-control"
                                           id="profileContactNo">

                                </div>

                                <div>

                                    <label>
                                        Birthday
                                    </label>

                                    <input type="date"
                                           class="form-control"
                                           id="profileBirthday"
                                           readonly>

                                </div>

                            </div>

                        </div>



                        <!-- PASSWORD -->

                        <div class="profile-section-card">

                            <div class="section-header">

                                <div>

                                    <h5 class="mb-1">

                                        Change Password

                                    </h5>

                                    <small class="password-requirements">

                                        Password must contain uppercase, lowercase,
                                        number, and symbol.

                                    </small>

                                </div>

                                <button class="btn btn-danger"
                                        id="changePasswordBtn">

                                    Update Password

                                </button>

                            </div>

                            <div class="profile-grid">

                                <!-- CURRENT -->

                                <div>

                                    <label>

                                        Current Password

                                    </label>

                                    <div class="password-wrapper">

                                        <input type="password"
                                               class="form-control"
                                               id="currentPassword">

                                        <button type="button"
                                                class="password-toggle"
                                                data-target="currentPassword">

                                            <i class="bi bi-eye"></i>

                                        </button>

                                    </div>

                                </div>



                                <!-- NEW -->

                                <div>

                                    <label>

                                        New Password

                                    </label>

                                    <div class="password-wrapper">

                                        <input type="password"
                                               class="form-control"
                                               id="newPassword">

                                        <button type="button"
                                                class="password-toggle"
                                                data-target="newPassword">

                                            <i class="bi bi-eye"></i>

                                        </button>

                                    </div>

                                </div>



                                <!-- CONFIRM -->

                                <div>

                                    <label>

                                        Confirm Password

                                    </label>

                                    <div class="password-wrapper">

                                        <input type="password"
                                               class="form-control"
                                               id="confirmPassword">

                                        <button type="button"
                                                class="password-toggle"
                                                data-target="confirmPassword">

                                            <i class="bi bi-eye"></i>

                                        </button>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>



                    <!-- ===================================== -->
                    <!-- RIGHT COLUMN -->
                    <!-- ===================================== -->

                    <div class="profile-right-column">

                        <div class="profile-section-card">

                            <div class="section-header">

                                <h5>

                                    Address Book

                                </h5>

                                <button class="btn btn-success"
                                        id="addAddressBtn">

                                    <i class="bi bi-plus-circle"></i>

                                    Add Address

                                </button>

                            </div>

                            <div id="addressContainer">

                                <!-- Addresses loaded here -->

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>




<!--Add New Address modal-->
<!-- ADD ADDRESS MODAL -->

<div class="modal fade"
     id="addAddressModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog
                modal-lg
                modal-dialog-scrollable">

        <div class="modal-content">

            <!-- HEADER -->

            <div class="modal-header">

                <h5 class="modal-title">

                    Add New Address

                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="bg-light border rounded px-3 py-2 mb-3">
                <small class="text-danger fw-semibold">
                    (*) Fields marked with an asterisk (*) are required.
                </small>
            </div>

            <!-- BODY -->

            <div class="modal-body">

                <div class="row g-3">

                    <!-- HOUSE / UNIT -->

                    <div class="col-md-6">

                        <label class="form-label">
                            * House / Unit
                        </label>

                        <input type="text"
                               class="form-control"
                               id="addHouseUnit">

                    </div>

                    <!-- STREET -->

                    <div class="col-md-6">

                        <label class="form-label">
                            * Street Name
                        </label>

                        <input type="text"
                               class="form-control"
                               id="addStreetName">

                    </div>

                    <!-- ZIP -->

                    <div class="col-md-6">

                        <label class="form-label">
                            * ZIP Code
                        </label>

                        <input type="text"
                               class="form-control"
                               id="addZipCode">

                    </div>

                    <!-- LANDMARK -->

                    <div class="col-md-6">

                        <label class="form-label">
                            * Landmark
                        </label>

                        <input type="text"
                               class="form-control"
                               id="addLandmark">

                    </div>

                    <!-- REGION -->

                    <div class="col-md-6">

                        <label class="form-label">
                            * Region
                        </label>

                        <select class="form-select"
                                id="addRegion">

                            <option value="">
                                -- Select Region --
                            </option>

                        </select>

                    </div>

                    <!-- PROVINCE -->

                    <div class="col-md-6">

                        <label class="form-label">
                            * Province
                        </label>

                        <select class="form-select"
                                id="addProvince"
                                disabled>

                            <option value="">
                                -- Select Province --
                            </option>

                        </select>

                    </div>

                    <!-- MUNICIPALITY -->

                    <div class="col-md-6">

                        <label class="form-label">
                            * Municipality
                        </label>

                        <select class="form-select"
                                id="addMunicipality"
                                disabled>

                            <option value="">
                                -- Select Municipality --
                            </option>

                        </select>

                    </div>

                    <!-- BARANGAY -->

                    <div class="col-md-6">

                        <label class="form-label">
                            * Barangay
                        </label>

                        <select class="form-select"
                                id="addBarangay"
                                disabled>

                            <option value="">
                                -- Select Barangay --
                            </option>

                        </select>

                    </div>

                </div>

            </div>

            <!-- FOOTER -->

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancel

                </button>

                <button type="button"
                        class="btn btn-success"
                        id="saveAddressBtn">

                    Save Address

                </button>

            </div>

        </div>

    </div>

</div>

<script src="~/js/view-js/layout_search.js"></script>
<script src="~/js/shop_my_profile.js"></script>


