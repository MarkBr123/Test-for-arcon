@model ARCon_Capstone_2.Views.Home.Services.RepairModel
@{
}

@{
    ViewData["Title"] = "Repair Services";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Repair.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Cleaning.css" asp-append-version="true" />
}

    <!-- Main Repair Form Section -->
<section class="repair-form-section" id="service-cont">
        <h2>Repair Request Form</h2>

        <div class="progress-indicator">
            <div class="progress-step active" data-page="1">
                <span class="progress-step-number">1</span>
                <span>Service Details</span>
            </div>
            <div class="progress-step" data-page="2">
                <span class="progress-step-number">2</span>
                <span>Personal Information</span>
            </div>
        </div>

        <form id="serviceForm" class="service-form">
            <!-- Page 1: Service Details -->
            <div id="page1" class="form-page active">
                <div class="form-left">

                    <!-- ================= AIRCON PAGE LAYOUT ================= -->
                    <div class="form-split">

                        <!-- ============ LEFT SIDE ============ -->
                        <div class="panel">

                            <h2>Repair or System Reprocess</h2>

                            <!-- Aircon Entries Container -->
                            <div id="airconEntries">

                                <!-- First Aircon Entry -->
                                <div class="aircon-entry" data-aircon-id="1">

                                    <div class="aircon-entry-header">
                                        <div class="aircon-entry-title">Service #1</div>
                                        <button type="button"
                                                class="remove-aircon-btn hidden"
                                                data-aircon="1"
                                                aria-label="Remove service">
                                            ×
                                        </button>
                                    </div>

                                    <!-- Row 1 -->
                                    <div class="aircon-entry-content">

                                        <div class="form-group">
                                            <label for="acType-1">AC Type *</label>
                                            <select id="acType-1"
                                                    class="ac-type"
                                                    data-aircon="1"
                                                    required>
                                            </select>
                                        </div>

                                        <div class="form-group">
                                            <label for="serviceType-1">Service Type *</label>
                                            <select id="serviceType-1"
                                                    class="service-type"
                                                    data-aircon="1"
                                                    required>
                                            </select>
                                        </div>

                                    </div>

                                    <!-- Row 2 -->
                                    <div class="aircon-entry-content">

                                        <div class="form-group">
                                            <label for="priceTier-1">Price Tier *</label>
                                            <select id="priceTier-1"
                                                    class="price-tier"
                                                    data-aircon="1"
                                                    required>
                                                <option value="">Select Price Tier...</option>
                                            </select>
                                        </div>

                                        <div class="form-group">
                                            <label for="brand-1">Brand (Optional)</label>
                                            <select id="brand-1"
                                                    class="aircon-brand"
                                                    data-aircon="1">
                                                <option value="">Select Brand...</option>
                                                <option value="Samsung">Samsung</option>
                                                <option value="LG">LG</option>
                                                <option value="Panasonic">Panasonic</option>
                                                <option value="Daikin">Daikin</option>
                                                <option value="Koppel">Koppel</option>
                                                <option value="Fujidenzo">Fujidenzo</option>
                                                <option value="Sharp">Sharp</option>
                                                <option value="other">Other</option>
                                            </select>
                                        </div>

                                    </div>

                                    <!-- Row 3 -->
                                        <div class="form-group">
                                            <label>Issue / Problem</label>
                                            <textarea id="repairProblem-1"
                                                      class="repair-problem form-control"
                                                      rows="3"
                                                      placeholder="Describe the issue with this AC..."></textarea>
                                        </div>


                                    <!-- Row 4 -->
                                    <div class="units-warranty">

                                        <div class="form-group">
                                            <label>Number of Units *</label>
                                            <div class="counter-box">
                                              
                                                <input type="number"
                                                       class="units-input"
                                                       value="1"
                                                       min="1"
                                                       max="10"
                                                       data-aircon="1"
                                                       required>

                                            </div>
                                        </div>

                                    </div>

                                </div>
                            </div>

                            <button type="button" class="btn-add-aircon primary" id="addAirconBtn">
                                <span class="plus">+</span>
                                Add Another Aircon
                            </button>
                        </div>


                        <!-- ============ RIGHT SIDE ============ -->
                        <div class="price-card">
                            <div class="price-label">Estimated Total</div>
                            <div class="price-value" id="estimatedPrice">₱ 0</div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Page 2: Review & Booking -->
            <div id="page2" class="form-page">

                <div class="booking-grid">

                    <!-- ================= LEFT SIDE ================= -->
                    <div class="booking-left">
                        <div class="summary-panel">
                            <h2>Services Included</h2>
                            <div id="airconSummaryContainer" class="services-list">
                                <!-- JS renders service_booking_items here -->
                            </div>
                        </div>
                    </div>
                    <!-- ================= RIGHT SIDE ================= -->
                    <div class="booking-right">

                        <h2>Booking Details</h2>

                        <!-- Customer Type -->
                        <div class="form-group">
                            <label>Customer Type *</label>
                            <div class="radio-group">
                                <label>
                                    <input type="radio" name="customer_type" value="PERSONAL" checked>
                                    Personal
                                </label>
                                <label>
                                    <input type="radio" name="customer_type" value="BUSINESS">
                                    Business
                                </label>
                            </div>
                        </div>

                        <!-- Business Name -->
                        <div class="form-group">
                            <label>Business Name</label>
                            <input type="text" id="businessName" name="business_name"
                                   placeholder="Required if Business" disabled>
                        </div>

                        <!-- Service Address -->
                        <div class="form-group">
                            <label>Service Address *</label>

                            <button type="button" id="chooseAddressBtn" class="address-btn">
                                + Choose Service Address
                            </button>

                            <!-- Selected Address Preview -->
                            <div id="selectedAddressBox" class="selected-address hidden">
                                <div id="selectedAddressText"></div>
                                <button type="button" id="changeAddressBtn" class="link-btn">
                                    Change
                                </button>
                            </div>

                            <!-- Hidden value for form submit -->
                            <input type="hidden" id="customerAddressId" name="customer_address_id" required>
                        </div>

                        <!-- Property Type -->
                        <div class="form-group">
                            <label>Property Type *</label>
                            <select name="property_type" required>
                                <option value="">Select...</option>
                                <option value="HOUSE">House</option>
                                <option value="CONDO">Condo</option>
                                <option value="CORPORATE">Corporate</option>
                                <option value="BUSINESS">Business</option>
                            </select>
                        </div>

                        <!-- Schedule Date -->
                        <div class="form-group">
                            <label>Schedule Date *</label>
                            <input type="date" id="scheduleDate" name="schedule_date" required>
                        </div>

                        <!-- Preferred Time -->
                        <div class="mb-3">
                            <label class="form-label">Preferred Service Time</label>
                            <input type="time"
                                   id="preferredTime"
                                   min="08:00"
                                   max="18:00" />
                        </div>

                        <!-- Customer Note -->
                        <div class="form-group">
                            <label>Customer Note</label>
                            <textarea name="customer_note" rows="3"
                                      placeholder="Special instructions for technicians..."></textarea>
                        </div>

                        <!-- Payment Method -->
                        <div class="form-group">
                            <label>Payment Method *</label>
                            <div class="radio-group">
                                <label>
                                    <input type="radio" name="payment_method" value="ONLINE_PAYMENT" required>
                                    Online Payment
                                </label>
                                <label>
                                    <input type="radio" name="payment_method" value="AFTER_SERVICE">
                                    Pay After Service
                                </label>
                            </div>
                        </div>

                        <!-- 🔥 ONLINE PAYMENT SECTION -->
                        <div id="onlinePaymentSection" class="mt-3" style="display:none;">

                            <div class="card p-3 shadow-sm border-0">
                                <h6 class="mb-3">💳 Card Details</h6>

                                <!-- Card Number -->
                                <div class="form-group mb-2">
                                    <label>Card Number *</label>
                                    <input type="text"
                                           id="cardNumber"
                                           class="form-control"
                                           placeholder="4343 4343 4343 4345"
                                           maxlength="19">
                                </div>

                                <div class="row">
                                    <!-- Expiry Month -->
                                    <div class="col-4">
                                        <label>Month *</label>
                                        <input type="number"
                                               id="expMonth"
                                               class="form-control"
                                               placeholder="MM"
                                               min="1"
                                               max="12">
                                    </div>

                                    <!-- Expiry Year -->
                                    <div class="col-4">
                                        <label>Year *</label>
                                        <input type="number"
                                               id="expYear"
                                               class="form-control"
                                               placeholder="YYYY"
                                               min="2024">
                                    </div>

                                    <!-- CVC -->
                                    <div class="col-4">
                                        <label>CVC *</label>
                                        <input type="number"
                                               id="cvc"
                                               class="form-control"
                                               placeholder="123"
                                               maxlength="4">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr />

                        <!-- Total Amount -->
                        <div class="total-box">
                            <span>Total Amount</span>
                            <strong id="totalAmount">₱ 0.00</strong>
                        </div>

                        <!-- Book Button -->
                        <!--<button type="submit" class="btn-primary btn-full">
                            Book Service
                        </button>-->

                    </div>

                </div>
            </div>

            <!-- Navigation Buttons -->
            <div class="buttons">
                <button type="button" class="back-btn hidden" id="backBtn">Back</button>
                <button type="button" class="next-btn" id="nextBtn">Next</button>
                <button type="submit" class="submit-btn hidden" id="submitBtn">Book Service</button>
            </div>

        </form>
    </section>

    

   
    <!-- Footer Section -->
    <footer class="footer-section">
        <div class="footer-content">
            <p>© 2024 Aircon Repair Services. All rights reserved.</p>
        </div>
    </footer>
</div>


<!--Address-->
<div class="modal fade" id="addressModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Select Service Address</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div id="addressListContainer" class="address-list"></div>
            </div>

        </div>
    </div>
</div>


<!--Success Modal-->
<div class="modal fade" id="successModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">🎉 Booking Confirmed!</h5>
            </div>

            <div class="modal-body">
                <p class="mb-2">
                    Thank you for choosing our Airconi repair service!
                </p>

                <p class="mb-2">
                    Your booking has been successfully received and our team will
                    review the schedule shortly.
                </p>

                <div class="alert alert-success mb-0">
                    <strong>Reference Number:</strong><br>
                    <span id="successBookingId" class="fs-5 fw-bold"></span>
                </div>

                <p class="mt-3 mb-0 text-muted">
                    Please save this reference number for tracking your service.
                </p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-success" id="successOkBtn">
                    View Booking Details
                </button>
            </div>

        </div>
    </div>
</div>

<!--Unsuccesful Modal-->
<div class="modal fade" id="errorModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">⚠️ Booking Not Completed</h5>
            </div>

            <div class="modal-body">
                <p class="mb-2">
                    We’re sorry — your booking could not be completed at the moment.
                </p>

                <div class="alert alert-danger mb-2">
                    <span id="errorMessage">
                        Something went wrong while processing your request.
                    </span>
                </div>

                <p class="mb-0 text-muted">
                    Please review your details and try again.
                    If the issue continues, feel free to contact our support team.
                </p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Go Back
                </button>
                <button type="button" class="btn btn-danger" id="retryBtn">
                    Try Again
                </button>
            </div>

        </div>
    </div>
</div>


<!--Validation Modal-->
<div class="modal fade" id="infoModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">⚠️ Please Check Your Booking</h5>
            </div>
            <div class="modal-body">
                <p id="infoMessage">Missing required information.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-warning" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>


<script>
    const IS_LOGGED_IN = @ViewBag.IsLoggedIn.ToString().ToLower();
    const LOGIN_URL = '/Shop/Home/Login';
</script>

<script src="~/js/Repair.js"></script>