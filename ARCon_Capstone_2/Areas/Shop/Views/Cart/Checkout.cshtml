@{
    ViewData["Title"] = "Checkout";
}

<div class="container checkout-page">
    <div class="row">
        <!-- LEFT: SHIPPING DETAILS -->
        <div class="col-md-7">
            <h3 class="section-title">Fill in shipping details.</h3>

            <form method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>First name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="FirstName" value="Inoh" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Last name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="LastName" value="Susano" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label>Country <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" value="Philippines" readonly />
                </div>

                <div class="mb-3">
                    <label>Street address <span class="text-danger">*</span></label>
                    <input type="text" class="form-control mb-2" placeholder="House number and street name" required />
                    <input type="text" class="form-control" placeholder="Apartment, suite, unit, etc. (optional)" />
                </div>

                <div class="mb-3">
                    <label>City <span class="text-danger">*</span></label>
                    <select class="form-select" required>
                        <option selected>Caloocan</option>
                        <option>Quezon City</option>
                        <option>Manila</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label>Region <span class="text-danger">*</span></label>
                    <select class="form-select" required>
                        <option selected>Metro Manila</option>
                        <option>Region IV-A</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label>Barangay <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" required />
                </div>
            </form>
        </div>

        <!-- RIGHT: ORDER SUMMARY -->
        <div class="col-md-5">
            <div class="order-summary">
                <h4>Your order</h4>
                <hr />

                <div class="d-flex justify-content-between">
                    <strong>Product</strong>
                    <strong>Subtotal</strong>
                </div>

                <div class="product-item">
                    <div>
                        <strong>Kolin KA-200MCARINV32</strong><br />
                        <small>2.0 HP Window Type Airconditioner - 2025</small>
                    </div>
                    <div>₱29,695</div>
                </div>

                <hr />

                <div class="d-flex justify-content-between">
                    <span>Subtotal</span>
                    <span>₱29,695</span>
                </div>

                <div class="mt-3">
                    <strong>Shipping</strong>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" checked />
                        <label class="form-check-label">
                            Standard Delivery (L): ₱400
                        </label>
                    </div>
                    <div class="form-check text-muted">
                        <input class="form-check-input" type="radio" disabled />
                        <label class="form-check-label">
                            Pick Up In Store (Click & Collect)
                        </label>
                    </div>
                </div>

                <hr />

                <div class="d-flex justify-content-between total">
                    <strong>Total</strong>
                    <strong>₱30,095</strong>
                </div>

                <div class="mt-3">
                    <label>Preferred Delivery Date <span class="text-danger">*</span></label>
                    <input type="date" class="form-control" required />
                </div>

                <div class="mt-3">
                    <label>Preferred Delivery Time Slot <span class="text-danger">*</span></label>
                    <select class="form-select" required>
                        <option>8:00 AM – 12:00 PM</option>
                        <option>1:00 PM – 5:00 PM</option>
                    </select>
                </div>

                <button class="btn btn-danger w-100 mt-4">
                    Place Order
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .checkout-page {
        margin-top: 40px;
    }

    .section-title {
        border-bottom: 2px solid #e53935;
        padding-bottom: 10px;
        margin-bottom: 20px;
    }

    .order-summary {
        background: #fff;
        border: 1px solid #ddd;
        padding: 20px;
        border-radius: 6px;
    }

    .product-item {
        display: flex;
        justify-content: space-between;
        margin: 15px 0;
    }

    .total {
        font-size: 18px;
    }
</style>
