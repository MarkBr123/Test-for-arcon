@page
@model ARCon_Capstone_2.Areas.Shop.Views.Home.SigninModel

@section Styles {
    <link rel="stylesheet"
          href="~/css/Login.css"
          asp-append-version="true" />
}

<div class="signup-page">

    <div class="signup-card">

        <!-- FORM -->
        <form id="signupForm">

            <!-- LEFT COLUMN -->
            <div class="signup-form">

                <h2>Sign Up</h2>

                <p class="subtitle">
                    Welcome to our website, let’s get started
                </p>

                <p class="subtitle">
                    Please fill all the required fields (*).
                </p>

                <!-- BASIC INFO -->

                <h6>Basic Information</h6>

                <div class="name-row">

                    <input id="fname"
                           name="first_name"
                           type="text"
                           placeholder="*First name"
                           required />

                    <input id="mname"
                           name="middle_name"
                           type="text"
                           placeholder="Middle name" />

                    <input id="lname"
                           name="last_name"
                           type="text"
                           placeholder="*Last name "
                           required />

                </div>

                <h6>*Birthday</h6>
                <input id="birthday"
                       name="birthday"
                       type="date"
                       required
                       min="1904-01-01"
                       max="2007-12-31" />

                <!-- ADDRESS -->

                <h6>*Physical Address</h6>
                <input id="house_unit"
                       name="house_unit"
                       type="text"
                       placeholder="*House / Unit" />

                <input id="street_name"
                       name="street_name"
                       type="text"
                       placeholder="*Street" />

                <div class="name-row">

                    <select id="region"
                            name="region_id"
                            required>

                        <option value="">
                            -- Select Region --
                        </option>

                    </select>

                    <select id="province"
                            name="province_id"
                            disabled
                            required>

                        <option value="">
                            -- Select Province --
                        </option>

                    </select>

                </div>

                <div class="name-row">

                    <select id="municipality"
                            name="municipality_id"
                            disabled
                            required>

                        <option value="">
                            -- Select Municipality / City --
                        </option>

                    </select>

                    <select id="barangay"
                            name="barangay_id"
                            disabled
                            required>

                        <option value="">
                            -- Select Barangay --
                        </option>

                    </select>

                </div>

                <input id="zip_code"
                       name="zip_code"
                       type="text"
                       placeholder="*Zip Code" />

                <input id="landmark"
                       name="landmark"
                       type="text"
                       placeholder="*Landmark" />

            </div>

            <!-- RIGHT COLUMN -->

            <div class="signup-right">

                <div class="signup-form-right">

                    <!-- CONTACT -->

                    <h6>Contact</h6>


                    <input id="email"
                           name="email"
                           type="email"
                           placeholder="*Email address"
                           required />

                    <input id="contact"
                           name="contact_no"
                           type="text"
                           placeholder="*Contact number"
                           required />

                    <!-- PASSWORD -->

                    <strong><h6>Password</h6></strong>
                    <h7><i>Password must be at least 8 characters, contain uppercase, lowercase, number, and symbol.</i></h7>

                    <div class="password-wrapper">

                        <input id="password"
                               name="password"
                               type="password"
                               placeholder="*Password"
                               required />

                        <button type="button"
                                id="toggleMainPassword"
                                class="password-toggle-btn"
                                data-target="password"
                                aria-label="Show password">

                            👁

                        </button>

                    </div>

                    <div class="password-wrapper">

                        <input id="cpassword"
                               name="confirm_password"
                               type="password"
                               placeholder="*Confirm Password"
                               required />

                        <button type="button"
                                id="toggleConfirmPassword"
                                class="password-toggle-btn"
                                data-target="cpassword"
                                aria-label="Show confirm password">

                            👁

                        </button>

                    </div>

                    <!-- CREATE ACCOUNT -->
                    <!-- NEXT BUTTON -->

                    <button type="button"
                            id="btnNextToTerms">

                        Next

                    </button>

                </div>

                <!-- IMAGE -->

                <div class="illustration">

                    <img src="~/ImageSources/Background/repair.jpg"
                         alt="Illustration" />

                </div>

            </div>

        </form>

        <!-- TOASTS -->

        <div id="toastContainer"></div>

    </div>

</div>



