<!-- SERVICES SECTION  -->

<section class="services" id="services">
    <!-- Hero Section -->
    <div class="services-hero">
        <div class="services-hero-content">
            <h1>Professional Aircon Services</h1>
            <p>Expert solutions for all your air conditioning needs with guaranteed quality and fast turnaround</p>
        </div>
        <div class="services-hero-image">
            <div class="hero-image-placeholder">
                <img src="~/ImageSources/Service/hero-service.jpg" alt="Aircon Services" onerror="this.src='https://placehold.co/400x280/3498db/white?text=Aircon+Service'">
            </div>
        </div>
    </div>

    <!-- Service Cards  -->
    <div class="service-cards-wrapper">
        <div class="service-cards-header">
            <h2>Our Services</h2>
            <p>Choose from our range of professional services</p>
        </div>

        <div class="service-grid-2col">
            <!-- Left Column -->
            <div class="service-col">
                <!-- Cleaning -->
                <div class="service-card-horizontal">
                    <div class="card-icon-small">
                        <img src="~/ImageSources/Service/clean.png" alt="Cleaning">
                    </div>
                    <div class="card-content">
                        <h3>Cleaning</h3>
                        <p>Thorough aircon cleaning for better efficiency</p>
                        <a asp-controller="Service" asp-action="Cleaning" class="card-link">Book Now →</a>
                    </div>
                </div>

                <!-- Repair -->
                <div class="service-card-horizontal">
                    <div class="card-icon-small">
                        <img src="~/ImageSources/Service/repairing.jpg" alt="Repair">
                    </div>
                    <div class="card-content">
                        <h3>Repair</h3>
                        <p>Fast and reliable repair services</p>
                        <a asp-controller="Service" asp-action="Repair" class="card-link">Book Now →</a>
                    </div>
                </div>
            </div>

            <!-- Right Column -->
            <div class="service-col">
                <!-- Freon Charging -->
                <div class="service-card-horizontal">
                    <div class="card-icon-small">
                        <img src="~/ImageSources/Service/charging.jpg" alt="Freon Charging">
                    </div>
                    <div class="card-content">
                        <h3>Freon Charging</h3>
                        <p>Professional refrigerant recharge</p>
                        <a asp-controller="Service" asp-action="Freoncharging" class="card-link">Book Now →</a>
                    </div>
                </div>

                <!-- Installing -->
                <div class="service-card-horizontal">
                    <div class="card-icon-small">
                        <img src="~/ImageSources/Service/install.png" alt="Installing">
                    </div>
                    <div class="card-content">
                        <h3>Installing</h3>
                        <p>Expert installation for new units</p>
                        <a asp-controller="Service" asp-action="Installing" class="card-link">Book Now →</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="faq-section">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-container">
        <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
                What types of aircon services do you offer?
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p>We offer a complete range of aircon services including Cleaning, Repair, Freon Charging, and Installation for all major brands and types of air conditioning units.</p>
            </div>
        </div>

        <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
                How often should I get my aircon serviced?
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p>For optimal performance, we recommend cleaning every 3-4 months and a full maintenance check at least twice a year. Regular servicing extends the life of your unit and reduces electricity consumption.</p>
            </div>
        </div>

        <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
                Do you offer warranty on your services?
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p>Yes! All our services come with a 90-day service warranty. Replacement parts have their own manufacturer warranty for your peace of mind.</p>
            </div>
        </div>

        <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
                What areas do you serve?
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p>We serve the entire Metro Manila area and select nearby provinces. You can check our service coverage during the booking process.</p>
            </div>
        </div>

        <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
                How do I book a service?
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p>Simply click the "Book Now" button on any service card, fill out the service request form, and our team will confirm your schedule within 24 hours.</p>
            </div>
        </div>

        <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
                Are your technicians certified?
                <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
                <p>Absolutely! All our technicians are fully certified, trained, and experienced in handling all types of air conditioning units from major brands.</p>
            </div>
        </div>
    </div>
</section>

<section class="bottom-note">
    <p>AIR-CON: offers high-quality products with fast and reliable services!</p>
</section>

<section class="bottom-image">
    <div class="overlay"></div>
