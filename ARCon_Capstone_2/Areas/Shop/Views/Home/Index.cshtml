@{
    ViewData["Title"] = "Air-Con";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Search.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons"
          rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}

@section Scripts {
    <script src="~/js/View-js/Index.js" asp-append-version="true"></script>
}


@* Page Headline *@
<div class="toolbar" id="tb">

    <!-- Dropdown 1 -->
    <div class="text-dropdown" id="d1">
        <span class="material-icons" id="list-icon">list</span>
        <span class="dropdown-label" id="caterogries">Sort by Categories </span>
        <div class="dropdown-menu">
            <div class="dropdown-item">Inverter</div>
            <div class="dropdown-item">Non-Inverter</div>
            <div class="dropdown-item">Price: High to Low</div>
            <div class="dropdown-item">Price: Low to High</div>
        </div>
    </div>

    <!-- Brands -->
    <div class="text-dropdown" id="d2">
        <span class="dropdown-label">Brands ▾</span>
        <div class="dropdown-menu">
            <div class="dropdown-item" data-value="Samsung">Samsung</div>
            <div class="dropdown-item" data-value="LG">LG</div>
            <div class="dropdown-item" data-value="Kolin">Kolin</div>
            <div class="dropdown-item" data-value="Daikin">Daikin</div>
            <div class="dropdown-item" data-value="TCL">TCL</div>
        </div>
    </div>

    <!-- HP -->
    <div class="text-dropdown" id="d2">
        <span class="dropdown-label">HP ▾</span>
        <div class="dropdown-menu">
            <div class="dropdown-item" data-value="1">1 HP</div>
            <div class="dropdown-item" data-value="1.5">1.5 HP</div>
            <div class="dropdown-item" data-value="2">2 HP</div>
        </div>
    </div>

    <div class="text-dropdown" id="d2">
        <span class="dropdown-label">Form  ▾</span>
        <div class="dropdown-menu">
            <div class="dropdown-item" data-value="Split">Split</div>
            <div class="dropdown-item" data-value="Ceiling">Ceiling</div>
            <div class="dropdown-item" data-value="Stand">Stand</div>
            <div class="dropdown-item" data-value="Window">Window</div>
        </div>
    </div>

    <!-- Buttons -->
    <button class="text-button" id="b1">🔥 Best Deals</button>
    <button class="text-button" id="b2">🚛 Free Shipping</button>
    <button class="text-button" id="b3">⭐ Top Picks</button>
    @* <button class="text-button" id="b4"></button> *@

</div>

<section class="hero">
    <div class="container">
        <div class="row">
            <div class="col-6" id="img-carousel">
                <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="2500">

                    <div class="carousel-inner" id="banner-l">

                        <!-- First Slide -->
                        <div class="carousel-item active">
                            <img src="~/ImageSources/Banner/INDOOR_CIRCUIT_BREAKER_FOR_SELECTED_MODELS.png" class="d-block w-100" alt="banner1">
                        </div>

                        <!-- Second Slide -->
                        <div class="carousel-item">
                            <img src="~/ImageSources/Banner/New1.png" class="d-block w-100" alt="banner2">
                        </div>

                        <!-- Third Slide -->
                        <div class="carousel-item">
                            <img src="~/ImageSources/Banner/New2.png" class="d-block w-100" alt="banner3">
                        </div>

                    </div>

                    <!-- Carousel Controls -->
                    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>

                </div>
            </div>

            <div class="col-6">
                <div class="row">
                    <div class="col-12">
                        <div class="banner-img" id="banner-r1">
                            <img src="~/ImageSources/Banner/ELECTRICAL_LINE_UP_TO_10FT.png" alt="banner">
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="banner-img" id="banner-r2">
                            <img src="~/ImageSources/Banner/HEAVY_DUTY_WALLTYPE_BRACKET.png" alt="banner">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @* <div class="hero-text">
        <h1>Best Aircon Distributor In Town</h1>
        <p>We sell top quality for affordable prices.</p>
        <p>Fast and reliable delivery.</p>
        <p>Customer satisfaction guaranteed.</p>

        <a asp-controller="Home" asp-action="Featured" class="btn">Shop Now</a>
    </div> *@
</section>

@* Products *@
<section class="deals" id="best-deals">
    <h2>BEST DEALS</h2>

    <div class="deals-container">

        <button class="deal-btn prev" onclick="moveSlide(-1)">❮</button>

        <div class="deals-viewport">
            <div class="deals-track">
                @*  SLIDE 1  *@
                <div class="deal-slide">
                    <div class="deal-cards" id="bestDealsContainer">
                        <!-- Products will load here from API -->
                    </div>
                </div>

                @* SLIDE 2 *@
                <div class="deal-slide">
                    <div class="deal-cards">
                        <div class="card product-card text-dark">
                            <a asp-controller="Home" asp-action="Product">
                                <span class="badge discount">19% OFF</span>
                                <span class="badge stock">IN STOCK</span>
                                <img src="~/ImageSources/Product/LG.webp" alt="LG Window Inverter">
                                <h3>LG Window Inverter Try 4</h3>
                                <p>Product Description</p>
                                <p class="old-price">₱30,000</p>
                                <p class="price">₱16,190</p>
                            </a>
                            <div class="product-btns">
                                <button class="btn btn-primary" id="view-item" onclick="">
                                    View Item
                                </button>
                                <button class="btn btn-primary" onclick="addToCart({id: 1, name: 'LG Window Inverter LA08GC', price: 26190})">
                                    🛒
                                </button>
                            </div>
                        </div>

                        <div class="card product-card text-dark">
                            <a asp-controller="Home" asp-action="Product">
                                <span class="badge discount">19% OFF</span>
                                <span class="badge stock">IN STOCK</span>
                                <img src="~/ImageSources/Product/LG.webp" alt="LG Window Inverter">
                                <h3>LG Window Inverter Try 4</h3>
                                <p>Product Description</p>
                                <p class="old-price">₱30,000</p>
                                <p class="price">₱16,190</p>
                            </a>
                            <div class="product-btns">
                                <button class="btn btn-primary" id="view-item" onclick="">
                                    View Item
                                </button>
                                <button class="btn btn-primary" onclick="addToCart({id: 1, name: 'LG Window Inverter LA08GC', price: 26190})">
                                    🛒
                                </button>
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>

        <button class="deal-btn next" onclick="moveSlide(1)">❯</button>

    </div>
</section>


<!--Start This is the (10 Products Section)-->
<section class="deals">
    <h2>PRODUCT</h2>
    <div class="deal-cards" id="productContainer">
        <!-- Products will load here -->
    </div>
</section>
<!--End This is the (10 Products Section)-->

<section class="services" id="services">
    <h2>SERVICE</h2>
    <div class="service-grid">
        <div>
            <a asp-controller="Service" asp-action="Cleaning">
                <img src="~/ImageSources/Service/clean.png" alt="Cleaning">
            </a>
            <p>Cleaning</p>
        </div>

        <div>
            <a asp-controller="Service" asp-action="Repair">
                <img src="~/ImageSources/Service/repairing.jpg" alt="Repair">
            </a>
            <p>Repair</p>
        </div>

        <div>
            <a asp-controller="Service" asp-action="Freoncharging">
                <img src="~/ImageSources/Service/charging.jpg" alt="Freoncharging">
            </a>    
            <p>Freon Charging</p>
        </div>

        <div>
            <a asp-controller="Service" asp-action="Installing">
                <img src="~/ImageSources/Service/install.png" alt="Installing">
            </a>
            <p>Installing</p>
        </div>
    </div>
</section>

<section class="bottom-note">
    <p>AIR-CON: offers high-quality products with fast and reliable services!</p>
</section>

<section class="bottom-image">
    <div class="overlay"></div>
    <div class="text-overlay">
        <h1>Skilled and Well-trained Technicians</h1>
        <p>Expert service, anytime, anywhere.</p>
    </div>
    <img src="~/ImageSources/Background/owner.jpg" alt="Aircon">
</section>

