@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>Login</title>

    <link rel="stylesheet"
          href="~/css/Login.css"
          asp-append-version="true" />

    <link rel="icon"
          type="image/png"
          href="~/assets/favicon.png" />

</head>

<body>

    <div class="login-page">

        <div class="login-wrapper">

            <!-- LEFT SIDE -->

            <div class="login-illustration">

                <img src="~/ImageSources/Background/login.png"
                     alt="Illustration" />

            </div>

            <!-- RIGHT SIDE -->

            <div class="login-form">

                <h2>Login</h2>

                <p style="text-align:center;">
                    Welcome to AIRCON-i Appliance Trading Inc.
                    Sign in to shop, book services, and manage your account.
                </p>

                <form id="loginForm"
                      asp-controller="Auth"
                      asp-action="UserLogin"
                      asp-area=""
                      method="post">

                    <!-- ADMIN TOGGLE -->

                    <div class="admin-toggle">

                        <label class="admin-toggle-label">

                            <input type="checkbox"
                                   id="isAdminLogin" />

                            <span>
                                Login as Admin
                            </span>

                        </label>

                    </div>

                    <!-- ACCESS ID -->

                    <div class="form-group"
                         id="accessIdGroup"
                         style="display:none;">

                        <input type="text"
                               id="accessId"
                               name="accessId"
                               placeholder="AIRCON-i Access ID" />

                    </div>

                    <!-- IDENTIFIER -->

                    <div class="form-group">

                        <input type="text"
                               id="identifier"
                               name="identifier"
                               placeholder="Email or Contact Number"
                               required />

                    </div>

                    <!-- PASSWORD -->

                    <div class="form-group">

                        <div class="password-wrapper">

                            <input type="password"
                                   id="password"
                                   name="password"
                                   placeholder="Password"
                                   required />

                            <button type="button"
                                    id="togglePassword"
                                    class="password-toggle-btn">

                                👁

                            </button>

                        </div>

                    </div>

                    <!-- SERVER ERROR -->
                    @if (TempData["Error"] != null)
                    {
                        <div class="error-message">

                            @TempData["Error"]

                        </div>
                    }

                    <!-- LOGIN BUTTON -->

                    <button type="submit"
                            id="loginBtn"
                            class="btn-login">

                        Login

                    </button>

                </form>

                <!-- SIGNUP -->

                <div class="divider">

                    Or

                </div>

                <div id="account-note">

                    Doesn't have an account?

                </div>

                <div class="sign-btn">

                    <a asp-controller="Home"
                       asp-action="Signin">

                        Sign up

                    </a>

                </div>

            </div>

        </div>

    </div>

    <!-- TOAST CONTAINER -->

    <div id="toastContainer"></div>

    <!-- JS -->

    <script src="~/js/login.js"
            asp-append-version="true"></script>

</body>
</html>