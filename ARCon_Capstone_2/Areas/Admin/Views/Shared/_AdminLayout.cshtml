<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">

@{
    var isFluid = ViewData["IsFluid"] as bool? ?? false;

    var isFullHeight = ViewData["IsFullHeight"] as bool? ?? false;
}


@using System.Security.Claims

@{
    var role = Context.Session.GetString("UserRole");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Airconi Trading Admin</title>


    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="icon" type="image/png" href="~/assets/favicon.png" />
</head>

<body>

    <div class="admin-wrapper d-flex">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="logo-placeholder text-center p-3">
                <img src="/assets/airconi-logo.png" width="200" alt="Logo">
            </div>

            <div class="menu">

                <a href="/admin" class="menu-item">
                    <i class="bi bi-house-door-fill icon-home"></i>
                    <span>Home</span>
                </a>
                @if (role == "ADMIN" || role == "SUPER_ADMIN" || role == "CSM")
                {

                    <a href="/admin/adminusers" class="menu-item">
                        <i class="bi bi-people-fill icon-users"></i>
                        <span>Users & Roles</span>
                    </a>
                }


                @if (role == "AIRCON_TECHNICIAN" )
                        {
                            <a href="https://localhost:7224/admin/TechnicianCalendar/MyWorkSchedule" class="menu-item">
                                <i class="bi bi-calendar-week-fill icon-calendar"></i>
                                <span>My Calendar</span>
                            </a>
                        }


                @if (role == "ADMIN" || role == "SUPER_ADMIN")
                {
                    <!-- ACCORDION ITEM Suppliers -->
                    <div class="menu-item accordion-item has-submenu">
                        <div class="accordion-header">
                            <i class="bi bi-truck icon-suppliers"></i>
                            <span>Suppliers</span>
                            <span class="arrow">▸</span>
                        </div>

                        <div class="submenu">
                            <a href="/admin/supplier">
                                <i class="bi bi-people icon-sub"></i>
                                Suppliers
                            </a>
                        </div>
                    </div>
                }



                    <!-- ACCORDION ITEM services -->
                    <div class="menu-item accordion-item has-submenu">
                        <div class="accordion-header">
                            <i class="bi bi-tools icon-services"></i>
                            <span>Service Request</span>
                            <span class="arrow">▸</span>
                        </div>

                        <div class="submenu">
                             @if (role == "ADMIN" || role == "SUPER_ADMIN" || role == "CSM")
                           {
                            <a href="/admin/services/for_confirmation">
                                <i class="bi bi-hourglass-split icon-sub"></i>
                                For Confirmation
                            </a>

                            <a href="/admin/services/processing">
                                <i class="bi bi-gear-wide-connected icon-sub"></i>
                                Processing
                            </a>

                            <a href="/admin/services/tech_assign">
                                <i class="bi bi-person-workspace icon-sub"></i>
                                Technician Assignment
                            </a>

                            <a href="/admin/services/scheduled">
                                <i class="bi bi-calendar-check icon-sub"></i>
                                Scheduled
                            </a>

                            <a href="/Admin/Services/All_Bookings">
                                <i class="bi bi-clock-history icon-sub"></i>
                                All Booking History
                            </a>
                            }
                                        <a href="/admin/services/all_service_transactions">
                                            <i class="bi bi-clock-history icon-sub"></i>
                                            All Service History
                                        </a>
                          @if (role == "ADMIN" || role == "SUPER_ADMIN" || role == "CSM")
                           {
                            <a href="/admin/services">
                                    <i class="bi bi-list-ul icon-sub"></i>
                                    Services Offered
                                </a>

                           }
                        </div>
                    </div>
                



                @if (role == "ADMIN" || role == "SUPER_ADMIN" || role == "CSM")
                {
                    <!-- ACCORDION ITEM Customer Orders -->
                    <div class="menu-item accordion-item has-submenu">
                        <div class="accordion-header">
                            <i class="bi bi-bag-check icon-orders"></i>
                            <span>Customer Orders</span>
                            <span class="arrow">▸</span>
                        </div>

                        <div class="submenu">

                            <a href="/admin/transactions">
                                <i class="bi bi-credit-card icon-sub"></i>
                                Payment Pendings
                            </a>

                            <a href="/admin/transactions/processing">
                                <i class="bi bi-gear-wide-connected icon-sub"></i>
                                Processing
                            </a>

                            <a href="/admin/transactions/forshipping">
                                <i class="bi bi-box-arrow-up icon-sub"></i>
                                For Shipping
                            </a>

                            <a href="/admin/transactions/intransit">
                                <i class="bi bi-truck icon-sub"></i>
                                In Transit
                            </a>

                            <a href="/admin/transactions/delivered">
                                <i class="bi bi-check-circle icon-sub"></i>
                                Delivered
                            </a>

                            <a href="/admin/transactions/cancelled_failed">
                                <i class="bi bi-x-circle icon-sub"></i>
                                Cancelled / Failed
                            </a>


                        </div>
                    </div>
                }


                @if (role == "ADMIN" || role == "SUPER_ADMIN" || role == "CSM")
                {
                    <!-- ACCORDION ITEM Inventory -->
                    <div class="menu-item accordion-item has-submenu">
                        <div class="accordion-header">
                            <i class="bi bi-box-seam icon-inventory"></i>
                            <span>Inventory and Stocks</span>
                            <span class="arrow">▸</span>
                        </div>

                        <div class="submenu">

                            <a href="/admin/inventory">
                                <i class="bi bi-archive icon-sub"></i>
                                Inventory
                            </a>

                            <a href="/admin/products">
                                <i class="bi bi-box icon-sub"></i>
                                Products
                            </a>

                            <a href="/admin/purchaseorders/index">
                                <i class="bi bi-receipt icon-sub"></i>
                                Purchase Orders
                            </a>

                            <a href="/admin/ReturnOrders/ReturnIndex">
                                <i class="bi bi-arrow-return-left icon-sub"></i>
                                Return Orders
                            </a>

                        </div>
                    </div>
                }
                        
                @if (role == "ADMIN" || role == "SUPER_ADMIN" || role == "CSM")
                {
                    <!-- ACCORDION Waranties -->
                    <div class="menu-item accordion-item has-submenu">
                        <div class="accordion-header">
                            <i class="bi bi-shield-check icon-inventory"></i>
                            <span>Warranty</span>
                            <span class="arrow">▸</span>
                        </div>
                        <div class="submenu">
                            <a href="/admin/Warranty/Outright_Replacement_Request">
                                <i class="bi bi-arrow-repeat icon-sub"></i>
                                Outright Replacement Requests
                            </a>

                            <a href="/admin/Warranty/Service_Warranty_Request">
                                <i class="bi bi-archive icon-sub"></i>
                                Service Warranty Requests
                            </a>
                        </div>
                    </div>
                }

 


                <!-- ACCORDION ITEM conversation -->
                <div class="menu-item accordion-item has-submenu">
                    <div class="accordion-header">
                        <i class="bi bi-chat-dots icon-chat"></i>
                        <span>Conversations</span>
                        <span class="arrow">▸</span>
                    </div>

                    <div class="submenu">
                        <a href="/admin/conversations">
                            <i class="bi bi-chat-left-text icon-sub"></i>
                            All Conversations
                        </a>
                    </div>
                </div>



                @if (role == "ADMIN" || role == "SUPER_ADMIN" || role == "CSM")
                {
                    <!-- ACCORDION ITEM utilities-->
                    <div class="menu-item accordion-item has-submenu">
                        <div class="accordion-header">
                            <i class="bi bi-sliders icon-utilities"></i>
                            <span>Utilities</span>
                            <span class="arrow">▸</span>
                        </div>

                        <div class="submenu">
                            <a href="/admin/utilities">
                                <i class="bi bi-gear icon-sub"></i>
                                System Utilities
                            </a>
                        </div>
                    </div>
                }


            </div>
        </aside>

        <!-- MAIN -->
        <div class="main flex-grow-1 d-flex flex-column">

            <!-- TOP NAVBAR -->
            <nav class="navbar top-navbar d-flex justify-content-end gap-3 px-3">

                <!-- Notifications -->
                <div class="dropdown">
                    <button class="btn btn-light position-relative" data-bs-toggle="dropdown">
                        <i class="bi bi-bell"></i>
                        <span class="badge bg-danger position-absolute top-0 start-100 translate-middle">3</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="#">Orders</a></li>
                        <li><a class="dropdown-item" href="#">Inventory</a></li>
                        <li><a class="dropdown-item" href="#">Service Request</a></li>
                        <li><a class="dropdown-item" href="#">Chats</a></li>
                    </ul>
                </div>

                <!-- User -->
                <div class="dropdown">
                    <button class="btn btn-light dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle"></i>
                        @Context.Session.GetString("UserType")
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="#">Profile</a></li>
                        <li><a class="dropdown-item" href="#">Schedule</a></li>
                        <li><a class="dropdown-item" href="#">Change Password</a></li>
                    </ul>
                </div>

                <!-- Logout -->
                <div class="dropdown">
                    <button class="btn btn-danger dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <form action="@Url.Action("LogoutPost", "Auth", new { area = "" })"
                                  method="post">

                                @Html.AntiForgeryToken()

                                <button type="submit" class="dropdown-item text-danger">
                                    Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>

                <button id="sidebarToggle" class="btn btn-light d-md-none">
                    <i class="bi bi-list"></i>
                </button>

            </nav>

            <!-- BODY -->
            <div class="admin-body flex-grow-1 @(isFluid ? "p-0" : "p-4") @(isFullHeight ? "full-height" : "")">
                @RenderBody()
            </div>

        </div>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="appConfirmModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">Are you sure?</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary btn-sm">OK</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div class="toast" id="appToast">
            <div class="toast-header">
                <strong class="me-auto">Notice</strong>
                <button class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body"></div>
        </div>
    </div>

    <!-- Loading Overlay -->
    <div id="loadingOverlay">
        <div class="spinner-wrapper">
            <div class="spinner-ring"></div>
            <img src="~/ImageSources/Logo/aircon.PNG" alt="Loading..." class="logo-center" />
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!--<script src="~/js/app-ui.js"></script>-->
    <script>

        ///// This is pair with css
        const toggleBtn = document.getElementById("sidebarToggle");
        const sidebar = document.querySelector(".sidebar");
        const overlay = document.getElementById("sidebarOverlay");

        toggleBtn?.addEventListener("click", () => {
            sidebar.classList.toggle("active");
            overlay.classList.toggle("active");
        });

        overlay?.addEventListener("click", () => {
            sidebar.classList.remove("active");
            overlay.classList.remove("active");
        });

        document.querySelectorAll(".accordion-header").forEach(header => {
            header.addEventListener("click", function (e) {
                e.stopPropagation();

                const item = this.parentElement;

                document.querySelectorAll(".accordion-item").forEach(i => {
                    if (i !== item) i.classList.remove("open");
                });

                item.classList.toggle("open");
            });
        });
            // 🔥 Force reload when coming from back/forward cache
            window.addEventListener("pageshow", function (event) {
                if (event.persisted || performance.getEntriesByType("navigation")[0]?.type === "back_forward") {
                    window.location.reload();
                }
            });

            /// For chat
            currentUserId = @Context.Session.GetInt32("UserId");
            currentUserType = "@Context.Session.GetString("UserType")";
                        window.currentUserId = @(Context.Session.GetInt32("UserId") ?? 0);
    </script>

    @RenderSection("Scripts", required: false)

    @* Loading spinner *@
    <script>
        window.chatUserId = '@(Context.Session.GetInt32("UserId") ?? 0)';
        window.chatUserType = '@(Context.Session.GetString("UserType") ?? "")';


        window.addEventListener("load", function () {
            var loader = document.getElementById("loadingOverlay");
            if (loader) {
                loader.style.display = "none";
            }

            // to show
            // document.getElementById("loadingOverlay").style.display = "flex";
        });

        window.addEventListener("pageshow", function (event) {
            if (event.persisted || performance.getEntriesByType("navigation")[0]?.type === "back_forward") {
                window.location.reload();
            }
        });
    </script>

</body>
</html>