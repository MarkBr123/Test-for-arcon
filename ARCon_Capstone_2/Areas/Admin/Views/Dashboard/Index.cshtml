<link rel="stylesheet" href="~/css/dashboard.css" />

@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-container">

    <!-- ===================================== -->
    <!-- DASHBOARD HERO -->
    <!-- ===================================== -->

    <div class="dashboard-hero">

        <div>

            <div class="dashboard-hero-title">

                Admin Dashboard

            </div>

            <div class="dashboard-hero-subtitle">

                AIRCON-i Aircon Trading Incorporated

            </div>

        </div>



        <div class="dashboard-hero-badge">

            <i class="bi bi-bar-chart-line-fill"></i>

            Operations Overview

        </div>

    </div>



    <!-- ===================================== -->
    <!-- MAIN GRID -->
    <!-- ===================================== -->

    <div class="dashboard-main-grid">

        <!-- ===================================== -->
        <!-- CUSTOMER TRANSACTIONS BLOCK -->
        <!-- ===================================== -->

        <div class="dashboard-block">

            <!-- HEADER -->
            <div class="dashboard-block-header">
                <div>
                    <div class="dashboard-block-title">
                        Customer Transaction Analytics
                    </div>
                    <div class="dashboard-block-subtitle">
                        Ecommerce sales and transaction insights
                    </div>
                </div>

                <i class="bi bi-graph-up-arrow dashboard-block-icon"></i>
            </div>

            <!-- KPI CARDS -->

            <div class="dashboard-summary-card card-primary">
                <div class="dashboard-summary-left">
                    <div class="dashboard-summary-label">
                        Total Transactions (Orders)
                    </div>

                    <div id="totalTransactions"
                         class="dashboard-summary-value">
                        --
                    </div>
                </div>

                <div class="dashboard-summary-icon">
                    <i class="bi bi-receipt-cutoff"></i>
                </div>
            </div>

            <div class="dashboard-summary-card card-success">
                <div class="dashboard-summary-left">
                    <div class="dashboard-summary-label">
                        Total Revenue (Product Sales)
                    </div>

                    <div id="totalRevenue"
                         class="dashboard-summary-value">
                        ₱0.00
                    </div>
                </div>

                <div class="dashboard-summary-icon">
                    <i class="bi bi-cash-stack"></i>
                </div>
            </div>

            <div class="dashboard-summary-card card-info">
                <div class="dashboard-summary-left">
                    <div class="dashboard-summary-label">
                        Average Order Value
                    </div>

                    <div id="averageOrderValue"
                         class="dashboard-summary-value">
                        ₱0.00
                    </div>
                </div>

                <div class="dashboard-summary-icon">
                    <i class="bi bi-calculator"></i>
                </div>
            </div>

            <!-- CHARTS -->

            <div class="dashboard-chart-container mt-4">
                <h6>Transactions Per Month</h6>
                <canvas id="transactionsPerMonthChart"></canvas>
            </div>

            <div class="dashboard-chart-container mt-4">
                <h6>Revenue Per Month</h6>
                <canvas id="revenuePerMonthChart"></canvas>
            </div>

            <div class="dashboard-chart-container mt-4">
                <h6>Payment Method Distribution</h6>
                <div class="payment-chart-container">
                    <canvas id="paymentMethodChart"></canvas>
                </div>
            </div>

            <div class="dashboard-chart-container mt-4">
                <h6>Transaction Status Distribution</h6>
                <canvas id="statusDistributionChart"></canvas>
            </div>

        </div>





        <!-- ===================================== -->
        <!-- SERVICE BOOKINGS ANALYTICS BLOCK -->
        <!-- ===================================== -->

        <div class="dashboard-block">

            <!-- HEADER -->

            <div class="dashboard-block-header">

                <div>

                    <div class="dashboard-block-title">

                        Service Booking Analytics

                    </div>

                    <div class="dashboard-block-subtitle">

                        Service operations monitoring and revenue insights

                    </div>

                </div>

                <i class="bi bi-tools dashboard-block-icon"></i>

            </div>



            <!-- TOTAL SERVICE BOOKINGS -->

            <div class="dashboard-summary-card card-primary">

                <div class="dashboard-summary-left">

                    <div class="dashboard-summary-label">

                        Total Service Bookings

                    </div>

                    <div id="serviceTotal"
                         class="dashboard-summary-value">

                        --

                    </div>

                </div>

                <div class="dashboard-summary-icon">

                    <i class="bi bi-tools"></i>

                </div>

            </div>



            <!-- TOTAL REVENUE -->

            <div class="dashboard-summary-card card-success">

                <div class="dashboard-summary-left">

                    <div class="dashboard-summary-label">

                        Total Revenue (Services)

                    </div>

                    <div id="serviceTotalRevenue"
                         class="dashboard-summary-value">

                        ₱ 0.00

                    </div>

                </div>

                <div class="dashboard-summary-icon">

                    <i class="bi bi-cash-stack"></i>

                </div>

            </div>



            <!-- AVERAGE SERVICE VALUE -->

            <div class="dashboard-summary-card card-info">

                <div class="dashboard-summary-left">

                    <div class="dashboard-summary-label">

                        Average Service Value

                    </div>

                    <div id="averageServiceValue"
                         class="dashboard-summary-value">

                        ₱0.00

                    </div>

                </div>

                <div class="dashboard-summary-icon">

                    <i class="bi bi-calculator"></i>

                </div>

            </div>



            <!-- SERVICE BOOKINGS PER MONTH -->

            <div class="dashboard-chart-container mt-4">

                <h6>Service Bookings Per Month</h6>

                <canvas id="serviceBookingPerMonthChart"></canvas>

            </div>



            <!-- SERVICE REVENUE PER MONTH -->

            <div class="dashboard-chart-container mt-4">

                <h6>Service Revenue Per Month</h6>

                <canvas id="serviceRevenuePerMonthChart"></canvas>

            </div>



            <!-- PAYMENT METHOD DISTRIBUTION -->

            <div class="dashboard-chart-container mt-4">

                <h6>Payment Method Distribution</h6>

                <div class="payment-chart-container">

                    <canvas id="servicePaymentMethodChart"></canvas>

                </div>

            </div>



            <!-- STATUS DISTRIBUTION -->

            <div class="dashboard-chart-container mt-4">

                <h6>Service Status Distribution</h6>

                <canvas id="serviceStatusDistributionChart"></canvas>

            </div>

        </div>


        <!-- ===================================== -->
        <!-- INVENTORY ANALYTICS BLOCK -->
        <!-- ===================================== -->

        <div class="dashboard-block">

            <!-- HEADER -->

            <div class="dashboard-block-header">

                <div>

                    <div class="dashboard-block-title">

                        Inventory Analytics

                    </div>

                    <div class="dashboard-block-subtitle">

                        Inventory insights and stock monitoring

                    </div>

                </div>

                <i class="bi bi-box-seam dashboard-block-icon"></i>

            </div>

                <div class="inventory-kpi-grid">

                        <!-- TOTAL SKUS -->

                        <div class="dashboard-summary-card card-primary">

                            <div class="dashboard-summary-left">

                                <div class="dashboard-summary-label">

                                    Total SKUs

                                </div>

                                <div id="totalSkus"
                                     class="dashboard-summary-value">

                                    --

                                </div>

                            </div>

                            <div class="dashboard-summary-icon">

                                <i class="bi bi-upc-scan"></i>

                            </div>

                        </div>



                        <!-- TOTAL UNITS -->

                        <div class="dashboard-summary-card card-info">

                            <div class="dashboard-summary-left">

                                <div class="dashboard-summary-label">

                                    Total Units

                                </div>

                                <div id="totalUnits"
                                     class="dashboard-summary-value">

                                    --

                                </div>

                            </div>

                            <div class="dashboard-summary-icon">

                                <i class="bi bi-boxes"></i>

                            </div>

                        </div>



                        <!-- ACTIVE PRODUCTS -->

                        <div class="dashboard-summary-card card-success">

                            <div class="dashboard-summary-left">

                                <div class="dashboard-summary-label">

                                    Active Products

                                </div>

                                <div id="activeProducts"
                                     class="dashboard-summary-value">

                                    --

                                </div>

                            </div>

                            <div class="dashboard-summary-icon">

                                <i class="bi bi-check-circle"></i>

                            </div>

                        </div>

                        <!-- Archived PRODUCTS -->

                        <div class="dashboard-summary-card card-secondary">

                            <div class="dashboard-summary-left">

                                <div class="dashboard-summary-label">

                                    Archived Products

                                </div>

                                <div id="archivedProducts"
                                     class="dashboard-summary-value">

                                    --

                                </div>

                            </div>

                            <div class="dashboard-summary-icon">

                                <i class="bi bi-archive-fill"></i>

                            </div>

                        </div>



                        <!-- DISCOUNTED PRODUCTS -->

                        <div class="dashboard-summary-card card-warning">

                            <div class="dashboard-summary-left">

                                <div class="dashboard-summary-label">

                                    Discounted Products

                                </div>

                                <div id="discountedProducts"
                                     class="dashboard-summary-value">

                                    --

                                </div>

                            </div>

                            <div class="dashboard-summary-icon">

                                <i class="bi bi-tag-fill"></i>

                            </div>

                        </div>



                        <!-- LOW STOCK -->

                        <div class="dashboard-summary-card card-danger">

                            <div class="dashboard-summary-left">

                                <div class="dashboard-summary-label">

                                    Low Stock Products

                                </div>

                                <div id="lowStockProducts"
                                     class="dashboard-summary-value">

                                    --

                                </div>

                            </div>

                            <div class="dashboard-summary-icon">

                                <i class="bi bi-exclamation-triangle-fill"></i>

                            </div>

                        </div>



                        <!-- OUT OF STOCK -->

                        <div class="dashboard-summary-card card-danger">

                            <div class="dashboard-summary-left">

                                <div class="dashboard-summary-label">

                                    Out of Stock Products

                                </div>

                                <div id="outOfStockProducts"
                                     class="dashboard-summary-value">

                                    --

                                </div>

                            </div>

                            <div class="dashboard-summary-icon">

                                <i class="bi bi-x-octagon-fill"></i>

                            </div>

                        </div>



                        <!-- UNITS SOLD -->

                        <div class="dashboard-summary-card card-success">

                            <div class="dashboard-summary-left">

                                <div class="dashboard-summary-label">

                                    Units Sold

                                </div>

                                <div id="unitsSold"
                                     class="dashboard-summary-value">

                                    --

                                </div>

                            </div>

                            <div class="dashboard-summary-icon">

                                <i class="bi bi-bag-check-fill"></i>

                            </div>

                </div>

            </div>

            <!-- STATUS DISTRIBUTION -->

            <div class="dashboard-chart-container mt-4">

                <h6>Inventory Status Distribution</h6>

                <div class="payment-chart-container">

                    <canvas id="inventoryStatusChart"></canvas>

                </div>

            </div>



            <!-- TOP PRODUCTS -->

            <div class="dashboard-chart-container mt-4">

                <h6>Best Selling Products</h6>

                <canvas id="topProductsChart"></canvas>

            </div>



            <!-- NEWEST PRODUCTS -->

            <div class="dashboard-chart-container mt-4">

                <h6>Newest Products</h6>

                <div id="newestProductsList">
                </div>

            </div>

        </div>





    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/js/dashboard.js"></script>