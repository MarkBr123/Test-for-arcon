<link rel="stylesheet" href="~/css/dashboard.css" />

@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-container">

    <!-- ===================================== -->
    <!-- DASHBOARD HERO -->
    <!-- ===================================== -->

    <div class="dashboard-hero">

        <div>

            <div class="dashboard-hero-title">

                Admin Dashboard

            </div>

            <div class="dashboard-hero-subtitle">

                AIRCON-i Aircon Trading Incorporated

            </div>

        </div>



        <div class="dashboard-hero-badge">

            <i class="bi bi-bar-chart-line-fill"></i>

            Operations Overview

        </div>

    </div>



    <!-- ===================================== -->
    <!-- MAIN GRID -->
    <!-- ===================================== -->

    <div class="dashboard-main-grid">

        <!-- ===================================== -->
        <!-- CUSTOMER TRANSACTIONS BLOCK -->
        <!-- ===================================== -->

        <div class="dashboard-block">

            <!-- HEADER -->

            <div class="dashboard-block-header">

                <div>

                    <div class="dashboard-block-title">

                        Customer Transactions

                    </div>

                    <div class="dashboard-block-subtitle">

                        Ecommerce transaction monitoring

                    </div>

                </div>

                <i class="bi bi-cart-check dashboard-block-icon"></i>

            </div>



            <!-- SUMMARY -->

            <div class="dashboard-summary-card card-primary">

                <div class="dashboard-summary-left">

                    <div class="dashboard-summary-label">

                        Total Transactions

                    </div>

                    <div id="totalTransactions"
                         class="dashboard-summary-value">

                        --

                    </div>

                </div>

                <div class="dashboard-summary-icon">

                    <i class="bi bi-receipt-cutoff"></i>

                </div>

            </div>



            <!-- DETAILS -->

            <div class="dashboard-details-list">

                <!-- PENDING -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-hourglass-split text-warning"></i>

                        <span>
                            Pending Confirmation
                        </span>

                    </div>

                    <div id="pendingConfirmation"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- CONFIRMED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-patch-check text-info"></i>

                        <span>
                            Confirmed
                        </span>

                    </div>

                    <div id="confirmedTransactions"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- PROCESSED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-box-seam text-primary"></i>

                        <span>
                            Processed
                        </span>

                    </div>

                    <div id="processedTransactions"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- REPROCESS -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-arrow-repeat text-orange"></i>

                        <span>
                            Pending Reprocess
                        </span>

                    </div>

                    <div id="pendingReprocess"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- COMPLETED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-check2-circle text-success"></i>

                        <span>
                            Completed
                        </span>

                    </div>

                    <div id="completedTransactions"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- REJECTED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-x-circle text-danger"></i>

                        <span>
                            Rejected
                        </span>

                    </div>

                    <div id="rejectedTransactions"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- REJECTED REFUND -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-cash-stack text-danger"></i>

                        <span>
                            Rejected For Refund
                        </span>

                    </div>

                    <div id="rejectedRefundTransactions"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- CANCELLED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-slash-circle text-secondary"></i>

                        <span>
                            Cancelled
                        </span>

                    </div>

                    <div id="cancelledTransactions"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- CANCELLED REFUND -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-wallet2 text-purple"></i>

                        <span>
                            Cancelled For Refund
                        </span>

                    </div>

                    <div id="cancelledRefundTransactions"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>

            </div>

        </div>





        <!-- ===================================== -->
        <!-- SERVICE BOOKINGS BLOCK -->
        <!-- ===================================== -->

        <div class="dashboard-block">

            <!-- HEADER -->

            <div class="dashboard-block-header">

                <div>

                    <div class="dashboard-block-title">

                        Service Bookings

                    </div>

                    <div class="dashboard-block-subtitle">

                        Service operations monitoring

                    </div>

                </div>

                <i class="bi bi-tools dashboard-block-icon"></i>

            </div>



            <!-- SUMMARY -->

            <div class="dashboard-summary-card card-primary">

                <div class="dashboard-summary-left">

                    <div class="dashboard-summary-label">

                        Total Service Bookings

                    </div>

                    <div id="serviceTotal"
                         class="dashboard-summary-value">

                        --

                    </div>

                </div>

                <div class="dashboard-summary-icon">

                    <i class="bi bi-tools"></i>

                </div>

            </div>



            <!-- DETAILS -->

            <div class="dashboard-details-list">

                <!-- PENDING -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-hourglass-split text-warning"></i>

                        <span>
                            Pending
                        </span>

                    </div>

                    <div id="servicePending"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- CONFIRMED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-check-circle text-info"></i>

                        <span>
                            Confirmed
                        </span>

                    </div>

                    <div id="serviceConfirmed"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- PROCESSING -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-gear-wide-connected text-primary"></i>

                        <span>
                            Processing
                        </span>

                    </div>

                    <div id="serviceProcessing"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- COMPLETED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-check2-all text-success"></i>

                        <span>
                            Completed
                        </span>

                    </div>

                    <div id="serviceCompleted"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- PARTIALLY COMPLETED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-exclamation-triangle text-orange"></i>

                        <span>
                            Partially Completed
                        </span>

                    </div>

                    <div id="servicePartiallyCompleted"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- WARRANTY -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-shield-check text-purple"></i>

                        <span>
                            Warranty Approved
                        </span>

                    </div>

                    <div id="serviceWarrantyApproved"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- FAILED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-x-circle text-danger"></i>

                        <span>
                            Failed
                        </span>

                    </div>

                    <div id="serviceFailed"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- FAILED REFUND -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-cash-stack text-danger"></i>

                        <span>
                            Failed For Refund
                        </span>

                    </div>

                    <div id="serviceFailedRefund"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- CANCELLED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-slash-circle text-secondary"></i>

                        <span>
                            Cancelled
                        </span>

                    </div>

                    <div id="serviceCancelled"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- REJECTED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-ban text-danger"></i>

                        <span>
                            Rejected
                        </span>

                    </div>

                    <div id="serviceRejected"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>

            </div>

        </div>


        <!-- ===================================== -->
        <!-- INVENTORY OVERVIEW BLOCK -->
        <!-- ===================================== -->

        <div class="dashboard-block">

            <!-- HEADER -->

            <div class="dashboard-block-header">

                <div>

                    <div class="dashboard-block-title">

                        Inventory Overview

                    </div>

                    <div class="dashboard-block-subtitle">

                        Inventory status monitoring

                    </div>

                </div>

                <i class="bi bi-box-seam dashboard-block-icon"></i>

            </div>



            <!-- SUMMARY -->

            <div class="dashboard-summary-card card-primary">

                <div class="dashboard-summary-left">

                    <div class="dashboard-summary-label">

                        Total Inventory

                    </div>

                    <div id="totalInventory"
                         class="dashboard-summary-value">

                        --

                    </div>

                </div>

                <div class="dashboard-summary-icon">

                    <i class="bi bi-boxes"></i>

                </div>

            </div>



            <!-- DETAILS -->

            <div class="dashboard-details-list">

                <!-- GOOD STOCK -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-check-circle-fill text-success"></i>

                        <span>
                            Good Stock
                        </span>

                    </div>

                    <div id="goodStock"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- RESERVED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-truck text-warning"></i>

                        <span>
                            Reserved For Delivery
                        </span>

                    </div>

                    <div id="reservedForDelivery"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- SOLD -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-bag-check-fill text-info"></i>

                        <span>
                            Sold
                        </span>

                    </div>

                    <div id="soldInventory"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- AS REPLACEMENT -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-arrow-repeat text-purple"></i>

                        <span>
                            As Replacement
                        </span>

                    </div>

                    <div id="asReplacement"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>



                <!-- RETURNED -->

                <div class="dashboard-detail-row">

                    <div class="dashboard-detail-left">

                        <i class="bi bi-arrow-return-left text-danger"></i>

                        <span>
                            Returned To Supplier
                        </span>

                    </div>

                    <div id="returnedToSupplier"
                         class="dashboard-detail-value">

                        --

                    </div>

                </div>

            </div>

        </div>





    </div>

</div>


<script src="~/js/dashboard.js"></script>