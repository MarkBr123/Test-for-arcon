

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
    .marvin-messenger {
        height: 100vh;
        font-family: Arial, sans-serif;
    }

        .marvin-messenger .mm-wrapper {
            height: 100%;
        }

        /* SIDEBAR */
        .marvin-messenger .mm-sidebar {
            width: 30%;
            border-right: 1px solid #ddd;
            display: flex;
            flex-direction: column;
            background: #fff;
        }

        .marvin-messenger .mm-tabs {
            display: flex;
        }

        .marvin-messenger .mm-tab {
            flex: 1;
            padding: 10px;
            border: none;
            background: #f5f5f5;
            cursor: pointer;
        }

            .marvin-messenger .mm-tab.active {
                background: #007bff;
                color: #fff;
            }

        .marvin-messenger .mm-search {
            padding: 10px;
        }

            .marvin-messenger .mm-search input {
                width: 100%;
                padding: 5px;
            }

        /* USER LIST */
        .marvin-messenger .mm-users {
            flex: 1;
            overflow-y: auto;
        }

        .marvin-messenger .mm-user {
            padding: 10px;
            border-bottom: 1px solid #eee;
            cursor: pointer;
        }

            .marvin-messenger .mm-user.active {
                background: #e7f1ff;
            }

        /* CHAT AREA */
        .marvin-messenger .mm-chat {
            width: 70%;
            display: flex;
            flex-direction: column;
        }

        .marvin-messenger .mm-header {
            padding: 10px;
            border-bottom: 1px solid #ddd;
            font-weight: bold;
        }

        .marvin-messenger .mm-messages {
            flex: 1;
            padding: 10px;
            overflow-y: auto;
            background: #f0f2f5;
        }

        .marvin-messenger .mm-message {
            max-width: 60%;
            padding: 8px 12px;
            margin: 5px 0;
            border-radius: 10px;
        }

        .marvin-messenger .mm-sent {
            background: #007bff;
            color: #fff;
            margin-left: auto;
        }

        .marvin-messenger .mm-received {
            background: #e4e6eb;
        }

        /* INPUT */
        .marvin-messenger .mm-input {
            display: flex;
            padding: 10px;
            border-top: 1px solid #ddd;
        }

            .marvin-messenger .mm-input input {
                flex: 1;
                padding: 5px;
            }

            .marvin-messenger .mm-input button {
                margin-left: 10px;
            }
    </style>


<div class="marvin-messenger">
    <div class="mm-wrapper d-flex">

        <!-- LEFT SIDE -->
        <div class="mm-sidebar">
            <div class="mm-tabs">
                <button class="mm-tab active">Internal</button>
                <button class="mm-tab">External</button>
            </div>

            <div class="mm-search">
                <input type="text" placeholder="Search...">
            </div>

            <div class="mm-users">
                <div class="mm-user active">
                    <strong>John Doe</strong>
                    <small>Last message...</small>
                </div>
                <div class="mm-user">
                    <strong>Jane Smith</strong>
                    <small>Hello there</small>
                </div>
            </div>
        </div>

        <!-- RIGHT SIDE -->
        <div class="mm-chat">
            <div class="mm-header">John Doe</div>

            <div class="mm-messages">
                <div class="mm-message mm-received">Hello!</div>
                <div class="mm-message mm-sent">Hi!</div>
            </div>

            <div class="mm-input">
                <input type="text" placeholder="Type a message">
                <button>Send</button>
            </div>
        </div>

    </div>
</div>

    <script>
        function switchTab(type) {
            const internal = document.getElementById('tab-internal');
            const external = document.getElementById('tab-external');
            const label = document.getElementById('chatTypeLabel');

            internal.classList.remove('active');
            external.classList.remove('active');

            if (type === 'INTERNAL') {
                internal.classList.add('active');
                label.innerText = "Internal Chat";
            } else {
                external.classList.add('active');
                label.innerText = "External Chat";
            }

            console.log("Load:", type);
        }
    </script>

