                            <!-- REORDER LEVEL -->
                            <div class="col-md-4">
                                <label class="form-label">Reorder Level</label>

                                <input type="number"
                                       class="form-control"
                                       id="editReorderLevel"
                                       readonly>
                            </div>

                            <!-- STATUS -->
                            <div class="col-md-4">
                                <label class="form-label">Status</label>

                                <input type="text"
                                       class="form-control"
                                       id="editStatus"
                                       readonly>
                            </div>

                            <!-- ACTUAL SELLING PRICE -->
                            <div class="col-md-4">
                                <label class="form-label">
                                    Actual Selling Price
                                </label>

                                <input type="number"
                                       class="form-control"
                                       id="editActualSellingPrice"
                                       readonly>
                            </div>

                            <!-- ========================================= -->
                            <!-- EDITABLE -->
                            <!-- ========================================= -->
                            <!-- ORIGINAL PRICE -->
                            <div class="col-md-4">
                                <label class="form-label">
                                    Original Selling Price
                                </label>

                                <input type="number"
                                       class="form-control"
                                       id="editOriginalSellingPrice">
                            </div>

                            <!-- DISCOUNT TYPE -->
                            <div class="col-md-4">
                                <label class="form-label">
                                    Discount Type
                                </label>

                                <select class="form-select"
                                        id="editDiscountType">
                                    <option value="NONE">None</option>
                                    <option value="PERCENTAGE">Percentage</option>
                                    <option value="AMOUNT">Amount</option>
                                </select>
                            </div>

                            <!-- DISCOUNT VALUE -->
                            <div class="col-md-4">
                                <label class="form-label">
                                    Discount Value
                                </label>

                                <input type="number"
                                       class="form-control"
                                       id="editDiscountValue">
                            </div>

                            <!-- DISCOUNTED PRICE -->
                            <div class="col-md-4">
                                <label class="form-label">
                                    Discounted Selling Price
                                </label>

                                <input type="number"
                                       class="form-control"
                                       id="editDiscountedSellingPrice"
                                       readonly>
                            </div>

                            <!-- AR URL -->
                            <div class="col-md-8">
                                <label class="form-label">
                                    AR URL
                                </label>

                                <input type="text"
                                       class="form-control"
                                       id="editArUrl">
                            </div>

                            <!-- WARRANTY -->
                            <div class="col-md-6">
                                <label class="form-label">
                                    Manufacturer Warranty Years
                                </label>

                                <input type="number"
                                       class="form-control"
                                       id="editWarrantyYears">
                            </div>

                            <!-- REPLACEMENT -->
                            <div class="col-md-6">
                                <label class="form-label">
                                    Outright Replacement Days
                                </label>

                                <input type="number"
                                       class="form-control"
                                       id="editReplacementDays">
                            </div>

                            <!-- WEIGHT A -->
                            <div class="col-md-4">
                                <label class="form-label">
                                    Gross Weight A
                                </label>

                                <input type="number"
                                       class="form-control"
                                       id="editGrossWeightA">
                            </div>

                            <!-- WEIGHT B -->
                            <div class="col-md-4">
                                <label class="form-label">
                                    Gross Weight B
                                </label>

                                <input type="number"
                                       class="form-control"
                                       id="editGrossWeightB">
                            </div>

                            <!-- TOTAL WEIGHT -->
                            <div class="col-md-4">
                                <label class="form-label">
                                    Total Gross Weight
                                </label>

                                <input type="number"
                                       class="form-control"
                                       id="editTotalGrossWeight"
                                       readonly>
                            </div>

                        </div>
                    </div>

                    <!-- ================================================= -->
                    <!-- SPECIFICATIONS -->
                    <!-- ================================================= -->

                    <div class="tab-pane fade"
                         id="specificationsTab">

                        <div class="d-flex justify-content-between align-items-center mb-3">

                            <div>
                                <h6 class="fw-semibold mb-0">
                                    Specifications
                                </h6>

                                <small class="text-muted">
                                    Manage technical specifications
                                </small>
                            </div>

                        </div>

                        <div id="specificationsContainer">
                            <!-- dynamic specs -->
                        </div>

                    </div>

                    <!-- ================================================= -->
                    <!-- TECHNOLOGIES -->
                    <!-- ================================================= -->

                    <div class="tab-pane fade"
                         id="technologiesTab">

                        <div class="d-flex justify-content-between align-items-center mb-3">

                            <div>
                                <h6 class="fw-semibold mb-0">
                                    Technologies
                                </h6>

                                <small class="text-muted">
                                    Product supported technologies
                                </small>
                            </div>

                            <button class="btn btn-sm btn-dark"
                                    id="addTechnologyBtn">
                                + Add Technology
                            </button>

                        </div>

                        <div id="technologiesContainer">
                            <!-- dynamic technologies -->
                        </div>

                    </div>

                    <!-- ================================================= -->
                    <!-- TAGS -->
                    <!-- ================================================= -->

                    <div class="tab-pane fade"
                         id="tagsTab">

                        <div class="mb-3">

                            <label class="form-label">
                                Tags
                            </label>

                            <input type="text"
                                   class="form-control"
                                   id="editTagsInput"
                                   placeholder="Example: Gaming, RGB, DDR5">
