@{
    ViewData["Title"] = "Utilities";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Utilities</h4>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#formFactors">
            Form Factors
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#techTypes">
            Technology Types
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#services">
            Services (AC Type & Categories)
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#manufacturers">
            Manufacturers
        </button>
    </li>
</ul>

<div class="tab-content">

    <div class="tab-pane fade show active" id="formFactors">
        <!-- Form Factor Table -->
    </div>

    <div class="tab-pane fade" id="techTypes">
        <!-- Technology Types Table -->
    </div>

    <div class="tab-pane fade" id="services">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="mb-0">Services (AC Type & Categories)</h6>

            <!-- SEARCH -->
            <div class="row mb-3">
                <div class="col-auto">
                    <input type="text"
                           id="servicesSearch"
                           class="form-control form-control-sm"
                           placeholder="Search services for category and aircon type....."
                           style="width: 620px;"
                           oninput="searchServices()" />
                </div>

            </div>
            <div class="btn-group">
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#acTypeModal">
                    + Service AC Type
                </button>
                <button class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#serviceCategoryModal">
                    + Service Category
                </button>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="manufacturers">
        <!-- Manufacturer Table -->
    </div>

</div>


<!--Modal for + Service AC Type-->
<div class="modal fade" id="acTypeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Add New AC Type</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">AC Type Name</label>
                    <input type="text"
                           id="acTypeName"
                           class="form-control"
                           placeholder="e.g. Window Type Inverter" />
                    <div class="invalid-feedback">
                        Aircon type name is required.
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="button"
                        class="btn btn-primary"
                        onclick="saveAcType()">
                    Save
                </button>
            </div>

        </div>
    </div>
</div>

<!--Modal for + Service Category-->
<div class="modal fade" id="serviceCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Add New Service Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Service Name</label>
                    <input type="text"
                           id="categoryName"
                           class="form-control"
                           placeholder="e.g. Dismantling" />
                    <div class="invalid-feedback">
                        Category name is required.
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <input type="text"
                           id="categoryDesc"
                           class="form-control"
                           placeholder="What this service is about?" />
                    <div class="invalid-feedback">
                        Brief description is required.
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="button"
                        class="btn btn-primary"
                        onclick="saveServiceCategory()">
                    Save
                </button>
            </div>

        </div>
    </div>
</div>

<script src="~/js/utilities.js"></script>