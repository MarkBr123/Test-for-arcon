@{
    ViewData["Title"] = "Receive PO Delivery";
    Layout = "_AdminLayout";
}
<link rel="stylesheet" href="~/css/render-rows.css" />
<div class="container-fluid">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Receive Purchase Order Delivery</h4>
        <a href="/Admin/Inventory" class="btn btn-outline-secondary btn-sm">
            ← Back to Inventory
        </a>
    </div>

    <!-- SECTION A: PO REFERENCE -->
    <div class="card mb-3">
        <div class="card-header fw-semibold">
            Section A – Purchase Order (Reference)
        </div>
        <div class="card-body">
            <button class="btn btn-outline-primary btn-sm"
                    onclick="openPoModal()">
                Select Purchase Order
            </button>

            <div id="poInfo" class="mt-3 d-none">
                <div class="row g-3">

                    <!-- ROW 1: Identity / Status -->
                    <div class="col-md-2">
                        <div class="text-muted small">PO #</div>
                        <div id="poNumber" class="fw-semibold">—</div>
                    </div>

                    <div class="col-md-2">
                        <div class="text-muted small">Supplier</div>
                        <div id="poSupplier" class="fw-semibold">—</div>
                    </div>

                    <div class="col-md-2">
                        <div class="text-muted small">Branch</div>
                        <div id="poBranch" class="fw-semibold">—</div>
                    </div>

                    <div class="col-md-2">
                        <div class="text-muted small">Status</div>
                        <div id="poStatus" class="fw-semibold">—</div>
                    </div>

                    <div class="col-md-2">
                        <div class="text-muted small">Payment</div>
                        <div id="poPayment" class="fw-semibold">—</div>
                    </div>

                    <div class="col-md-2">
                        <div class="text-muted small">Expected</div>
                        <div id="poExpected" class="fw-semibold">—</div>
                    </div>

                    <!-- ROW 2: Quantities / Money -->
                    <div class="col-md-2">
                        <div class="text-muted small">Items</div>
                        <div id="poItems" class="fw-semibold">—</div>
                    </div>

                    <div class="col-md-2">
                        <div class="text-muted small">Total Qty</div>
                        <div id="poQuantity" class="fw-semibold">—</div>
                    </div>

                    <div class="col-md-2">
                        <div class="text-muted small">Freight</div>
                        <div id="poFreight" class="fw-semibold">—</div>
                    </div>

                    <div class="col-md-2">
                        <div class="text-muted small">Total Amount</div>
                        <div id="poTotal" class="fw-semibold">—</div>
                    </div>

                </div>
            </div>



        </div>
    </div>

    <!-- SECTION B: PO ARTICLES (REFERENCE ONLY) -->
    <div class="card mb-3 d-none" id="poArticlesSection">
        <div class="card-header fw-semibold">
            Section B – PO Articles (Reference)
        </div>

        <div class="card-body table-responsive">
            <table class="table table-sm table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>SKU</th>
                        <th>Manufacturer</th>
                        <th>Model</th>
                        <th>Series</th>
                        <th>Part Number A</th>
                        <th class="text-center">Gross Weight</th>
                        <th>Form Factor</th>
                        <th class="text-center">Quantity</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end">Line Total</th>
                        <th class="text-center" style="width: 60px;">Copy to Actual</th>
                    </tr>
                </thead>

                <tbody id="poArticlesBody">
                    <!-- rows injected by JS -->
                </tbody>
            </table>
        </div>
    </div>



    <!-- SECTION C: ACTUAL DELIVERED ARTICLES -->
    <div class="card mb-3">
        <div class="card-header fw-semibold">
            Section C – Actual Delivered Articles
        </div>
        <div class="card-body">

            <button class="btn btn-outline-success btn-sm mb-2"
                    onclick="openProductModal()">
                + Add Delivered Product
            </button>

            <table class="table table-sm table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th class="text-center">Actual Quantity</th>
                        <th class="text-end">Actual Unit Price</th>
                        <th style="width: 40px;"></th>
                    </tr>
                </thead>
                <tbody id="deliveredItemsBody">
                    <!-- delivered items added here -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- ACTION -->
    <div class="text-end">
        <button class="btn btn-sm btn-outline-primary"
                onclick="openInventoryModalForAll()">
            Add to Inventory
        </button>



    </div>

</div>


<!-- PO SELECTION MODAL -->
<div class="modal fade" id="poModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Select Purchase Order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <table class="table table-sm table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>PO Number</th>
                            <th>Supplier</th>
                            <th>Expected Delivery</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th style="width: 80px;"></th>
                        </tr>
                    </thead>
                    <tbody id="poModalBody">
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                Loading purchase orders…
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm"
                        data-bs-dismiss="modal">
                    Close
                </button>
            </div>

        </div>
    </div>
</div>


<!--Add Delivered Products Modal-->
<div class="modal fade" id="productModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Add Product</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="text"
                       id="productSearchInput"
                       class="form-control form-control-sm mb-2"
                       placeholder="Search SKU, model, manufacturer…"
                       oninput="searchProducts()">

                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>SKU</th>
                                <th>Manufacturer</th>
                                <th>Model</th>
                                <th>Series</th>
                                <th>Form Factor</th>
                                <th style="width: 70px;"></th>
                            </tr>
                        </thead>
                        <tbody id="productModalBody"></tbody>
                    </table>
                </div>

            </div>

        </div>
    </div>
</div>


<!-- INVENTORY SERIAL ENTRY MODAL -->
<div class="modal fade"
     id="inventoryModal"
     tabindex="-1"
     data-bs-backdrop="static"
     data-bs-keyboard="false">

    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    Add to Inventory
                </h5>
                <button class="btn-close" onclick="confirmInventoryClose()"></button>
            </div>

            <div class="modal-body">

                <!-- PRODUCT INFO -->
                <div class="mb-3">
                    <div class="fw-semibold" id="inventoryProductName"></div>
                    <div class="text-muted small" id="inventoryProductMeta"></div>
                </div>
                <div>
                        <strong><h7>Input Unit/s serial number. All Serials must be input.</h7></strong>
                </div>
                <div class="mb-2 text-muted">
                    Quantity to add:
                    <strong id="inventoryQty"></strong>
                </div>

                <table class="table table-sm table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px;">#</th>
                            <th>Serial Number</th>
                        </tr>
                    </thead>
                    <tbody id="inventorySerialBody"></tbody>
                </table>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm"
                        onclick="confirmInventoryClose()">
                    Cancel
                </button>
                <button class="btn btn-primary btn-sm"
                        onclick="saveInventorySerials()">
                    Save to Inventory
                </button>
            </div>

        </div>
    </div>
</div>






<script src="~/js/inventory-receive-po.js"></script>