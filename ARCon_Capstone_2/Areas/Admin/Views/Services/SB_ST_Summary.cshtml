@{
    ViewData["Title"] = "Service Transaction Summary";
}
<link rel="stylesheet" href="~/css/render-rows.css" />
<style id="ui-polish">
    .card {
        border-radius: 10px;
        border: 1px solid #e5e7eb;
    }

    .card-header {
        background-color: #fff;
        border-bottom: 1px solid #e5e7eb;
        font-weight: 600;
    }

    .form-label {
        font-size: 12px;
        color: #6c757d;
        margin-bottom: 2px;
    }

    .form-control {
        font-weight: 500;
        background-color: #f9fafb;
        border: 1px solid #e5e7eb;
    }

    textarea.form-control {
        resize: none;
    }

    .table th {
        font-size: 12px;
        text-transform: uppercase;
        color: #6c757d;
    }

    .table td {
        vertical-align: middle;
    }

    .section-gap {
        margin-bottom: 1rem;
    }

    .action-hover {
        transition: all 0.2s ease;
    }

        .action-hover:hover {
            background-color: #f1f5ff;
            transform: translateX(3px);
        }

    .action-hover-danger:hover {
        background-color: #ffe5e5;
        transform: translateX(3px);
    }

</style>


<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-start flex-wrap mb-3">

        <!-- LEFT -->
        <div>
            <h4 class="mb-0 fw-bold">Service Transaction / Booking Summary</h4>
            <small class="text-muted">Detailed view of service transaction.</small>
        </div>

        <!-- RIGHT -->
        <div class="card" style="min-width: 260px;">
            <div class="card-body d-flex gap-4" id="headerTransactionInfo"></div>
        </div>

    </div>


    <div class="accordion" id="summaryAccordion">

                    <!-- BOOKING -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#bookingCollapse">
                                <i class="bi bi-journal-text me-2"></i>
                                Reference Booking Details
                            </button>
                        </h2>
                        <div id="bookingCollapse" class="accordion-collapse collapse show">
                            <div class="accordion-body row g-3" id="bookingSection"></div>
                        </div>
                    </div>

                    <!-- CUSTOMER & PAYMENT -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#customerCollapse">
                                <i class="bi bi-person me-2"></i>
                                Customer & Payment
                            </button>
                        </h2>
                        <div id="customerCollapse" class="accordion-collapse collapse">
                            <div class="accordion-body row g-3" id="customerSection"></div>
                        </div>
                    </div>

                    <!-- TRANSACTION -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#transactionCollapse">
                                <i class="bi bi-gear me-2"></i>
                                Service Transaction
                            </button>
                        </h2>
                        <div id="transactionCollapse" class="accordion-collapse collapse">
                            <div class="accordion-body row g-3" id="transactionSection"></div>
                        </div>
                    </div>

                    <!-- TECHNICIANS -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#techCollapse">
                                <i class="bi bi-people me-2"></i>
                                Assigned Technicians
                            </button>
                        </h2>
                        <div id="techCollapse" class="accordion-collapse collapse">
                            <div class="accordion-body row g-3" id="technicianSection"></div>
                        </div>
                    </div>

                    <!-- ITEMS -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#itemsCollapse">
                                <i class="bi bi-box-seam me-2"></i>
                                Service Request
                            </button>
                        </h2>
                        <div id="itemsCollapse" class="accordion-collapse collapse">
                            <div class="accordion-body" id="itemsSection"></div>
                        </div>
                    </div>

    </div>

</div>

<!-- ✅ LOAD JS FILE -->
<script src="@Url.Content("~/js/st-sb_st_summary.js")"></script>

<!-- ✅ INIT SCRIPT -->
<script>
    const transactionId = @Html.Raw(ViewBag.TransactionId ?? "null");

    console.log("Transaction ID:", transactionId);

    if (!transactionId) {
        document.getElementById("summaryContainer").innerHTML = `
                <div class="alert alert-danger">
                    Transaction ID is missing.
                </div>
            `;
    } else {
        loadFullSummary(transactionId);
    }
</script>