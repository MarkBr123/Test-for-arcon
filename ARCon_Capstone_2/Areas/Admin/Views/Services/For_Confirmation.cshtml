<link rel="stylesheet" href="~/css/render-rows.css" />

@{
    ViewData["Title"] = "For Confirmation";
    var status = "FOR_CONFIRMATION";
}


<div id="loadingSpinner" class="text-center my-3" style="display:none;">
    <div class="spinner-border text-primary" role="status"></div>
</div>

            <div class="header-bar">

                <!-- LEFT -->
                <div class="header-left">
                    <h4 class="mb-0">For Confirmation (Service)</h4>
                </div>

                <!-- CENTER -->
                <div class="header-center">
                    <input type="text"
                           id="forConfirmationSearchInput"
                           class="form-control"
                           placeholder="Search..." />
                </div>

                <!-- RIGHT -->
                <div class="header-right">
                    <button class="btn btn-primary d-flex align-items-center gap-2"
                            onclick="location.href='/Admin/Services/Processing'">
                        <i class="bi bi-plus-circle"></i>
                        Go to Processing >
                    </button>
                </div>

            </div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div id="serviceForConfirmationInfo" class="text-muted small mt-1"></div>
</div>


<div class="order-tracker">
    <a href="/Admin/Services/For_Confirmation"
       class="step @(status == "FOR_CONFIRMATION" ? "active" : "")">
        <div class="circle"></div>
        <span>For Confirmation</span>
    </a>

    <div class="line"></div>

    <a href="/Admin/Services/Processing"
       class="step @(status == "PROCESSING" ? "active" : "")">
        <div class="circle"></div>
        <span>Processing</span>
    </a>

    <div class="line"></div>

    <a href="/Admin/Services/Tech_Assign"
       class="step @(status == "TECH_ASSIGN" ? "active" : "")">
        <div class="circle"></div>
        <span>Technician Assignment</span>
    </a>

    <div class="line"></div>

    <a href="/Admin/Services/Scheduled"
       class="step @(status == "SCHEDULED" ? "active" : "")">
        <div class="circle"></div>
        <span>Scheduled</span>
    </a>
    <div class="line"></div>


    <a href="/Admin/Services/All_Service_Transactions"
       class="step @(status == "ALL_TRANSACTIONS" ? "active" : "")">
        <div class="circle"></div>
        <span>Service History</span>
    </a>
</div>


<br>
<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th></th> <!-- for arrow -->
            <th class="text-center small sortable" data-column="referenceCode" onclick="sort('referenceCode')">Reference Code</th>
            <th class="text-center small sortable" data-column="customerName" onclick="sort('customerName')">Customer Name</th>
            <th class="text-center small sortable" data-column="businessName" onclick="sort('businessName')">Business Name</th>
            <th class="text-center small sortable" data-column="scheduledDate" onclick="sort('scheduledDate')">Schedule Date</th>
            <th class="text-center small sortable" data-column="preferredTime" onclick="sort('preferredTime')">Preferred Time</th>
            <th class="text-center small sortable" data-column="paymentMethod" onclick="sort('paymentMethod')">Payment Method</th>
            <th class="text-center small sortable" data-column="totalAmount" onclick="sort('totalAmount')">Total Amount</th>
            <th class="text-center small sortable" data-column="propertyType" onclick="sort('propertyType')">Property Type</th>
            <th class="text-center small sortable" data-column="createdAt" onclick="sort('createdAt')">Order Placed At</th>
        </tr>
    </thead>

    <tbody id="pendingServicesTableBody">
        <!-- injected by JS -->
    </tbody>
</table>




<nav aria-label=" For_Confirmation (Service) Pagination" class="mt-3">
    <ul id="pagination" class="pagination justify-content-center">
        <!-- pagination injected by JS -->
    </ul>
</nav>


<!-- CONFIRM STEP 1 -->
<div class="modal fade" id="confirmStep1Modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Confirm Booking</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                Are you sure you want to confirm this booking?
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">No</button>
                <button class="btn btn-primary" id="step1YesBtn">Yes</button>
            </div>

        </div>
    </div>
</div>


<!-- CONFIRM STEP 2 -->
<div class="modal fade" id="confirmStep2Modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title text-danger">Final Confirmation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p>This action cannot be reverted.</p>
                <small class="text-danger">
                    Please wait <span id="countdown">5</span> seconds before confirming.
                </small>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger" id="finalConfirmBtn" disabled>
                    Yes, Confirm
                </button>
            </div>

        </div>
    </div>
</div>



<!-- REJECT STEP 1 -->
<div class="modal fade" id="rejectStep1Modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-3 shadow-sm">

            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    Reject Booking
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p class="mb-0">
                    Are you sure you want to reject this booking?
                </p>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    No
                </button>
                <button class="btn btn-danger"
                        onclick="handleRejectStep1Yes()">
                    Yes, Reject
                </button>
            </div>

        </div>
    </div>
</div>

<!-- REJECT STEP 2 -->
<div class="modal fade" id="rejectStep2Modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-3 shadow-sm">

            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    Final Warning
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <p class="mb-2">
                    This action will reject the booking.<br>
                    Please ensure the customer has been notified.
                </p>

                <small class="text-danger">
                    Please wait <span id="rejectCountdown">5</span> seconds before proceeding.
                </small>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button class="btn btn-danger"
                        id="rejectFinalBtn"
                        onclick="executeReject()"
                        disabled>
                    Yes, Reject Booking
                </button>
            </div>

        </div>
    </div>
</div>



<script src ="~/js/st-for_confirmation.js"></script>