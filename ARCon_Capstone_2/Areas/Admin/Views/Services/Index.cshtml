@{
    ViewData["Title"] = "Services";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Services</h4>

    <!-- SEARCH -->
    <div class="row mb-3">
        <div class="col-auto">
            <input type="text"
                   id="servicesSearch"
                   class="form-control form-control-sm"
                   placeholder="Search services for category and aircon type....."
                   style="width: 620px;"
                   oninput="searchServices()" />
        </div>

    </div>
    <div class="btn-group">
        <button class="btn btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#createServiceModal">
            + New Service
        </button>
    </div>

</div>

<!--parent and child table-->
<table class="table table-hover align-middle">
    <thead class="table-light">
    <thead>
        <tr>
            <th onclick="changeSort('airconType')">AC Type</th>
            <th onclick="changeSort('serviceName')">Service</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody id="servicesTable"></tbody>
</table>

<nav>
    <ul class="pagination justify-content-center" id="pagination"></ul>
</nav>


<!-- Modal for Service Creation -->
<div class="modal fade" id="createServiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Add New Service</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">AC Type</label>
                    <select id="acTypeSelect" class="form-select">
                        <option value="">-- Select AC Type --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Service Category</label>
                    <select id="serviceCategorySelect" class="form-select">
                        <option value="">-- Select Service Category --</option>
                    </select>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="button"
                        id="saveServiceBtn"
                        class="btn btn-primary"
                        onclick="saveService()">
                    Save Service
                </button>
            </div>

        </div>
    </div>
</div>

<!-- Add Price Tier Modal -->
<div class="modal fade" id="priceTierModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Add Price Tier</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="priceTierServiceId" />

                <div class="mb-2">
                    <label>Min HP</label>
                    <input type="number" step="0.1" id="minHp" class="form-control">
                </div>

                <div class="mb-2">
                    <label>Max HP</label>
                    <input type="number" step="0.1" id="maxHp" class="form-control">
                </div>

                <div class="mb-2">
                    <label>Price</label>
                    <input type="number" step="0.01" id="price" class="form-control">
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button class="btn btn-primary" onclick="savePriceTier()">
                    Save
                </button>
            </div>

        </div>
    </div>
</div>

<!-- Edit Price Tier Modal -->
<div class="modal fade" id="editPriceTierModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Edit Price Tier</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <!-- Tier ID for editing -->
                <input type="hidden" id="editPriceTierId" />
                <input type="hidden" id="editPriceTierServiceId" />

                <div class="mb-2">
                    <label>Min HP</label>
                    <input type="number" step="0.1" id="editMinHp" class="form-control">
                </div>

                <div class="mb-2">
                    <label>Max HP</label>
                    <input type="number" step="0.1" id="editMaxHp" class="form-control">
                </div>

                <div class="mb-2">
                    <label>Price</label>
                    <input type="number" step="0.01" id="editPrice" class="form-control">
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button class="btn btn-primary" onclick="saveEditedPriceTier()">
                    Update
                </button>
            </div>

        </div>
    </div>
</div>




<script src="~/js/services.js"></script>