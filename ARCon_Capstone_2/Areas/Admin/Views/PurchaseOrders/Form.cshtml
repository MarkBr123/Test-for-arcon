@{
    ViewData["Title"] = "Warranty Claim Summary";
}

<link rel="stylesheet"
      href="~/css/render-rows.css" />

<link rel="stylesheet"
      href="~/css/warranty-claim-summary.css" />


<div class="container-fluid px-3">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">

        <div>

            <h4 class="mb-1 fw-semibold">
                Warranty Claim Summary
            </h4>

            <small class="text-muted">
                Review warranty request details, customer information,
                and attached media.
            </small>

        </div>

        <a href="/Admin/Warranty/Service_Warranty_Request"
           class="btn btn-outline-secondary btn-sm">

            ← Back

        </a>

    </div>


    <!-- TABS -->
    <ul class="nav nav-pills mb-4"
        role="tablist">

        <!-- TAB 1 -->
        <li class="nav-item">

            <button class="nav-link active"
                    data-bs-toggle="pill"
                    data-bs-target="#warranty-info-pane"
                    type="button">

                <i class="bi bi-clipboard-check me-2"></i>
                Warranty Request Information

            </button>

        </li>

        <!-- TAB 2 -->
        <li class="nav-item">

            <button class="nav-link"
                    data-bs-toggle="pill"
                    data-bs-target="#warranty-media-pane"
                    type="button">

                <i class="bi bi-images me-2"></i>
                Media

            </button>

        </li>

    </ul>


    <!-- TAB CONTENT -->
    <div class="tab-content">

        <!-- ===================================================== -->
        <!-- TAB 1 -->
        <!-- ===================================================== -->

        <div class="tab-pane fade show active"
             id="warranty-info-pane">

            <div class="row g-4">

                <!-- WARRANTY DETAILS -->
                <div class="col-lg-6">

                    <div class="card h-100 shadow-sm border-0">

                        <div class="card-header fw-semibold">

                            <i class="bi bi-clipboard-check me-2"></i>
                            Warranty Details

                        </div>

                        <div class="card-body p-0">

                            <table class="table table-bordered mb-0 summary-table">

                                <tbody>

                                    <tr>

                                        <td class="summary-label">
                                            Warranty Code
                                        </td>

                                        <td id="summarySwbCode">
                                            -
                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Status
                                        </td>

                                        <td id="summaryStatus">
                                            -
                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Preferred Date
                                        </td>

                                        <td id="summaryPreferredDate">
                                            -
                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Preferred Time
                                        </td>

                                        <td id="summaryPreferredTime">
                                            -
                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Complaint
                                        </td>

                                        <td id="summaryComplaint"
                                            class="summary-text">

                                            -

                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Diagnosis Notes
                                        </td>

                                        <td id="summaryDiagnosisNotes"
                                            class="summary-text">

                                            -

                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Technician Notes
                                        </td>

                                        <td id="summaryTechnicianNotes"
                                            class="summary-text">

                                            -

                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Repeat Issue
                                        </td>

                                        <td id="summaryRepeatIssue">

                                            -

                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Created At
                                        </td>

                                        <td id="summaryCreatedAt">

                                            -

                                        </td>

                                    </tr>

                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>

                <!-- CUSTOMER & BOOKING -->
                <div class="col-lg-6">

                    <div class="card h-100 shadow-sm border-0">

                        <div class="card-header d-flex justify-content-between align-items-center">

                            <div class="fw-semibold">

                                <i class="bi bi-person-lines-fill me-2"></i>
                                Customer & Booking

                            </div>

                            <a id="viewBookingSummaryBtn"
                               href="#"
                               target="_blank"
                               class="btn btn-sm btn-outline-primary">

                                <i class="bi bi-box-arrow-up-right me-1"></i>
                                Booking Summary

                            </a>

                        </div>

                        <div class="card-body p-0">

                            <table class="table table-bordered mb-0 summary-table">

                                <tbody>

                                    <tr>

                                        <td class="summary-label">
                                            Booking Ref
                                        </td>

                                        <td id="summaryBookingRef">

                                            -

                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Booking Status
                                        </td>

                                        <td id="summaryBookingStatus">

                                            -

                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Customer Name
                                        </td>

                                        <td id="summaryCustomerName">

                                            -

                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Contact No
                                        </td>

                                        <td id="summaryContactNo">

                                            -

                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Email
                                        </td>

                                        <td id="summaryEmail">

                                            -

                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Paid At
                                        </td>

                                        <td id="summaryPaidAt">

                                            -

                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Booking Created At
                                        </td>

                                        <td id="summaryBookingCreatedAt">

                                            -

                                        </td>

                                    </tr>

                                    <tr>

                                        <td class="summary-label">
                                            Customer Note
                                        </td>

                                        <td id="summaryCustomerNote"
                                            class="summary-text">

                                            -

                                        </td>

                                    </tr>

                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>

            </div>

        </div>


        <!-- ===================================================== -->
        <!-- TAB 2 -->
        <!-- ===================================================== -->

        <div class="tab-pane fade"
             id="warranty-media-pane">

            <div class="card shadow-sm border-0">

                <div class="card-header fw-semibold">

                    <i class="bi bi-images me-2"></i>
                    Warranty Attachments

                </div>

                <div class="card-body">

                    <div class="row g-3"
                         id="warrantyMediaContainer">

                        <!-- Injected by JS -->

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>


<script src="~/js/warranty-claim-summary.js"></script>