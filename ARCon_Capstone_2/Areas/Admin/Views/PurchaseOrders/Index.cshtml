<link rel="stylesheet" href="~/css/render-rows.css" />


<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Purchase Orders</h4>

    <div class="row mb-3">
        <div class="col-auto">
            <input type="text"
                   id="purchaseOrderSearchInput"
                   class="form-control form-control-sm"
                   placeholder="Search purchase orders..."
                   style="width: 620px;"
                   oninput="searchPurchaseOrders()" />
        </div>
      
    </div>

    <button class="btn btn-primary d-flex align-items-center gap-2"
            onclick="location.href='/Admin/PurchaseOrders/Create'">
        <i class="bi bi-plus-circle"></i>
        New Purchase Order
    </button>   
</div>


<div class="d-flex justify-content-between align-items-center mb-3">
    <div id="poCountInfo" class="text-muted small mt-1"></div>
</div>
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th onclick="sortPurchaseOrders('po_number')" role="button">
                    PO Number
                </th>

                <th onclick="sortPurchaseOrders('supplier_name')" role="button">
                    Supplier
                </th>

                <th onclick="sortPurchaseOrders('arcon_branch_name')" role="button">
                    Airconi Branch
                </th>

                <th onclick="sortPurchaseOrders('status')" role="button">
                    Status
                </th>

                <th onclick="sortPurchaseOrders('payment_tyoe')" role="button">
                    Payment Type
                </th>

                <th onclick="sortPurchaseOrders('freight_cost')" role="button">
                    Expected Delivery
                </th>

                <th onclick="sortPurchaseOrders('expected_delivery')" role="button">
                    Freight Cost
                </th>

                <th onclick="sortPurchaseOrders('total_amount')" role="button">
                    Total Amount
                </th>

                <th class="text-center">
                    Items
                </th>

                <th class="text-center">
                    Total Qty
                </th>

                <th onclick="sortPurchaseOrders('_')" role="button">
                    Created At
                </th>

                <th onclick="sortPurchaseOrders('updated_At')" role="button">
                    Updated At
                </th>
                <th class="text-center">
                    Actions
                </th>
            </tr>
        </thead>

        <tbody id="purchaseOrdersTableBody">
            <!-- injected by JS -->
        </tbody>
    </table>

<nav aria-label="Purchase Orders Pagination" class="mt-3">
    <ul id="pagination" class="pagination justify-content-center">
        <!-- pagination injected by JS -->
    </ul>
</nav>


<script src="~/js/purchase-order-index.js"></script>