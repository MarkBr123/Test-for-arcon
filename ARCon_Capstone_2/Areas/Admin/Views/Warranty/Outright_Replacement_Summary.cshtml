<!-- TABS -->
<div class="d-flex justify-content-center mb-4">

    <ul class="nav nav-pills warranty-tabs"
        id="outrightReplacementSummaryTabs"
        role="tablist">

        <!-- TAB 1 -->
        <li class="nav-item"
            role="presentation">

            <button class="nav-link active"
                    id="replacement-info-tab"
                    data-bs-toggle="pill"
                    data-bs-target="#replacement-info-pane"
                    type="button"
                    role="tab">

                <i class="bi bi-arrow-repeat me-2"></i>

                Outright Replacement Information

            </button>

        </li>

        <!-- TAB 2 -->
        <li class="nav-item"
            role="presentation">

            <button class="nav-link"
                    id="replacement-items-tab"
                    data-bs-toggle="pill"
                    data-bs-target="#replacement-items-pane"
                    type="button"
                    role="tab">

                <i class="bi bi-box-seam me-2"></i>

                Product/s of Concern

            </button>

        </li>

        <!-- TAB 3 -->
        <li class="nav-item"
            role="presentation">

            <button class="nav-link"
                    id="replacement-media-tab"
                    data-bs-toggle="pill"
                    data-bs-target="#replacement-media-pane"
                    type="button"
                    role="tab">

                <i class="bi bi-images me-2"></i>

                Media

            </button>

        </li>

        <li class="nav-item"
            role="presentation">

            <button class="nav-link"
                    id="replacement-units-tab"
                    data-bs-toggle="pill"
