<link rel="stylesheet" href="~/css/render-rows.css" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Admin Users</h4>

    <div class="row mb-3">
        <div class="col-auto">
            <input type="text"
                   id="searchInput"
                   class="form-control form-control-sm"
                   placeholder="Search users..."
                   style="width: 620px;"
                   oninput="searchAdminUsers()" />
        </div>
    </div>

    <button type="button"
        id="btnOpenCreateUser"
        class="btn btn-primary"
        onclick="openCreateUserModal()">
    <i class="bi bi-person-plus me-1"></i> + New User
</button>
</div>



<div class="modal fade"
     id="createUserModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header">
                <h5 class="modal-title" id="adminUserModalTitle">
                    New Admin User
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>


            <!-- BODY -->
            <div class="modal-body">
                <!-- this will show errors -->
                <div id="createUserError"
                     class="alert alert-danger d-none mb-3">
                </div>


                <!-- TABS -->
                <ul class="nav nav-tabs mb-3">
                    <li class="nav-item">
                        <button class="nav-link active"
                                data-bs-toggle="tab"
                                data-bs-target="#cu-basic"
                                type="button">
                            Basic Information
                        </button>
                    </li>

                    <li class="nav-item">
                        <button class="nav-link"
                                data-bs-toggle="tab"
                                data-bs-target="#cu-schedule"
                                type="button">
                            Work Schedule
                        </button>
                    </li>
                </ul>

                <!-- TAB CONTENT -->
                <div class="tab-content">

                    <!-- BASIC INFO TAB -->
                    <div class="tab-pane fade show active"
                         id="cu-basic">

                        <div class="row g-3">

                            <div class="col-md-4">
                                <label class="form-label">Username</label>
                                <input id="cuUserName"
                                       class="form-control"
                                       autocomplete="off">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">First Name</label>
                                <input id="cuFirstName"
                                       class="form-control">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Last Name</label>
                                <input id="cuLastName"
                                       class="form-control">
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Email Address</label>
                                <input id="cuEmail"
                                       type="email"
                                       class="form-control">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Contact Number</label>
                                <input id="cuContactNo"
                                       class="form-control">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Home Address</label>
                                <input id="cuHomeAddress"
                                       class="form-control">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Birthday
                                </label>
                                <input id="cuBirthday"
                                       type="date"
                                       class="form-control"
                                       max="@DateTime.Today.AddYears(-18).ToString("yyyy-MM-dd")
                                       ">
                            </div>


                            <div class="col-md-6">
                                <label class="form-label">Role</label>
                                <select id="cuRole" class="form-select">
                                    <option value="">-- Select Role --</option>

                                    @foreach (var role in ViewBag.Roles)
                                    {
                                        <option value="@role.id">
                                            @role.role_name
                                        </option>
                                    }
                                </select>
                                <div id="roleSummaryText" class="form-control-plaintext d-none"></div>

                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Status</label>
                                <select id="cuStatus" class="form-select">
                                    <option value="ACTIVE">ACTIVE</option>
                                    <option value="SUSPENDED">SUSPENDED</option>                                    
                                </select>
                            </div>

                        </div>
                    </div>

                    <!-- WORK SCHEDULE TAB -->
                    <div class="tab-pane fade"
                         id="cu-schedule">

                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-light text-center">
                                <tr>
                                    <th style="width:20%">Day</th>
                                    <th style="width:25%">Login Time</th>
                                    <th style="width:25%">Logout Time</th>
                                    <th style="width:15%">Rest Day</th>
                                </tr>
                            </thead>

                            <!-- 🔴 THIS ID FIXES YOUR ERROR -->
                            <tbody id="scheduleBody">
                                <!-- injected by JS -->
                            </tbody>
                        </table>

                    </div>

                </div>
            </div>

            <!-- FOOTER -->
            <div class="modal-footer">
                <button type="button"
                        id="btnCancel"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="button"
                        id="btnSubmitAdminUser"
                        class="btn btn-success">
                    Create User
                </button>
            </div>

        </div>
    </div>
</div>


<!--Rows of admin_users-->
<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th onclick="sortUsers('user_name')" class="sortable">Username</th>
            <th onclick="sortUsers('last_name')" class="sortable">Last Name</th>
            <th onclick="sortUsers('first_name')" class="sortable">First Name</th>
            <th>Roles</th>
            <th onclick="sortUsers('email')" class="sortable">Email</th>
            <th>Contact Number</th>
            <th onclick="sortUsers('status')" class="sortable">Status</th>            
            <th>Home Address</th>          
            <th onclick="sortUsers('birthday')" class="sortable">Birthday</th>
            <th onclick="sortUsers('created_at')" class="sortable">Created At</th>
            <th onclick="sortUsers('updated_at')" class="sortable">Updated At</th>
            <th>Last Login</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody id="adminUsersTableBody">
        <!-- injected by JS -->
    </tbody>
</table>

    <nav class="mt-3">
        <ul class="pagination justify-content-center" id="pagination"></ul>
    </nav>


<script src="~/js/admin-users.js"></script>


