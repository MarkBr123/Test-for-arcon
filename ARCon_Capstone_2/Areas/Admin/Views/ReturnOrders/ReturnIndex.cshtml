@{
    ViewData["Title"] = "Supplier Returns";
}

<link rel="stylesheet" href="~/css/render-rows.css" />



<!-- ===================================== -->
<!-- HEADER -->
<!-- ===================================== -->

<div class="d-flex justify-content-between align-items-center mb-3">

    <h4 class="mb-0">

        Supplier Returns

    </h4>



    <div class="row mb-3">

        <div class="col-auto">

            <input type="text"
                   id="supplierReturnSearchInput"
                   class="form-control form-control-sm"
                   placeholder="Search supplier returns..."
                   style="width: 620px;"
                   oninput="searchSupplierReturns()" />

        </div>

    </div>



    <button class="btn btn-primary d-flex align-items-center gap-2"
            onclick="location.href='/Admin/ReturnOrders/NewReturnOrder'">

        <i class="bi bi-plus-circle"></i>

        New Return Order

    </button>

</div>



<!-- ===================================== -->
<!-- COUNT INFO -->
<!-- ===================================== -->

<div class="d-flex justify-content-between align-items-center mb-3">

    <div id="supplierReturnCountInfo"
         class="text-muted small mt-1">
    </div>

</div>



<!-- ===================================== -->
<!-- TABLE -->
<!-- ===================================== -->

<table class="table table-hover align-middle">

    <thead class="table-light">

        <tr>

            <th onclick="sortSupplierReturns('return_number')"
                role="button">

                Return Number

            </th>



            <th onclick="sortSupplierReturns('supplier_name')"
                role="button">

                Supplier

            </th>



            <th onclick="sortSupplierReturns('return_method')"
                role="button">

                Return Method

            </th>



            <th onclick="sortSupplierReturns('status')"
                role="button">

                Status

            </th>



            <th onclick="sortSupplierReturns('courier_name')"
                role="button">

                Courier

            </th>



            <th onclick="sortSupplierReturns('pickup_date')"
                role="button">

                Pickup Date

            </th>



            <th onclick="sortSupplierReturns('shipped_date')"
                role="button">

                Shipped Date

            </th>



            <th onclick="sortSupplierReturns('shipping_cost')"
                role="button">

                Shipping Cost

            </th>



            <th class="text-center">

                Total Items

            </th>



            <th onclick="sortSupplierReturns('total_amount')"
                role="button">

                Total Amount

            </th>



            <th onclick="sortSupplierReturns('created_at')"
                role="button">

                Created At

            </th>



            <th class="text-center">

                Actions

            </th>

        </tr>

    </thead>



    <tbody id="supplierReturnsTableBody">

        <!-- injected by JS -->

    </tbody>

</table>



<!-- ===================================== -->
<!-- PAGINATION -->
<!-- ===================================== -->

<nav aria-label="Supplier Returns Pagination"
     class="mt-3">

    <ul id="supplierReturnsPagination"
        class="pagination justify-content-center">

        <!-- pagination injected by JS -->

    </ul>

</nav>



<script src="~/js/supplier-return-index.js"></script>