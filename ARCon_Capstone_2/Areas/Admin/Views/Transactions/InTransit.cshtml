<!-- Fail Delivery Modal -->
<div class="modal fade" id="failDeliveryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Mark Delivery as Failed</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="failDeliveryId" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Failure Reason</label>
                    <select class="form-select" id="failReasonCode">
                        <option value="">Select reason</option>
                        <option value="Customer Not Available">Customer Not Available</option>
                        <option value="Customer Refused">Customer Refused</option>
                        <option value="Wrong Address">Wrong Address</option>
                        <option value="Requested Reschedule">Requested Reschedule</option>
                        <option value="COD Not Ready">COD Not Ready</option>
                        <option value="Damaged Item">Damaged Item</option>
                        <option value="Courier Issue">Courier Issue</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Additional Notes (Optional)</label>
                    <textarea class="form-control" id="failReason" rows="3"></textarea>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button class="btn btn-danger" onclick="confirmFailDelivery()">
                    Confirm Failure
                </button>
            </div>

        </div>
    </div>
</div>