@{
    ViewData["Title"] = "In Transit";

    var status = "IN_TRANSIT"; // or ViewBag.Status// PAYMENT_PENDING, PROCESSING, TO_SHIP, IN_TRANSIT, DELIVERED, CANCELLED
}
<div class="d-flex align-items-center mb-3">

    <!-- LEFT: Title -->
    <div>
        <h4 class="mb-0">In Transit</h4>
            @{

}
    </div>

    <!-- CENTER: Search -->
    <div class="flex-grow-1 d-flex justify-content-center">
        <input type="text"
               id="inTransitSearchInput"
               class="form-control form-control-sm"
               placeholder="Search for in transit deliveries..."
               style="max-width: 620px;" />
    </div>

</div>
<div class="d-flex justify-content-between align-items-center mb-3">
    <div id="inTransitTransactiontInfo" class="text-muted small mt-1"></div>
</div>

<div class="order-tracker">

    <a href="/Admin/Transactions/Index"
       class="step @(status == "PENDING_CONFIRMATION" ? "active" : "")">
        <div class="circle"></div>
        <span>Payment Pending</span>
    </a>

    <div class="line"></div>

    <a href="/Admin/Transactions/Processing"
       class="step @(status == "PROCESSING" ? "active" : "")">
        <div class="circle"></div>
        <span>Processing</span>
    </a>

    <div class="line"></div>

    <a href="/Admin/Transactions/ForShipping"
       class="step @(status == "BOOKED" ? "active" : "")">
        <div class="circle"></div>
        <span>To Ship</span>
    </a>

    <div class="line"></div>

    <a href="/Admin/Transactions/InTransit"
       class="step @(status == "IN_TRANSIT" ? "active" : "")">
        <div class="circle"></div>
        <span>In Transit</span>
    </a>

    <div class="line"></div>

    <!-- Delivered -->
    <a href="/Admin/Transactions/Delivered"
       class="step @(status == "DELIVERED" ? "active" : "")">
        <div class="circle"></div>
        <span>Delivered</span>
    </a>

    <div class="divider">|</div>

    <!-- Cancelled -->
    <a href="/Admin/Transactions/Cancelled_Failed"
       class="step @(status == "CANCELLED" ? "active" : "")">
        <div class="circle"></div>
        <span>Cancelled / Failed</span>
    </a>

</div>




<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th class="text-center small sortable" onclick="sort('deliveryRefCode')">
                Delivery Reference
            </th>
            <th class="text-center small sortable" onclick="sort('transactionCode')">
                Transaction Code
            </th>
            <th class="text-center small sortable" onclick="sort('customerName')">
                Customer NAme
            </th>
            <th class="text-center small sortable" onclick="sort('courier')">
                Courier
            </th>
            <th class="text-center small sortable" onclick="sort('scheduledAt')">
                Scheduled At
            </th>
            <th class="text-center small sortable" onclick="sort('scheduleStatus')">
                Schedule Status
            </th>
            <th class="text-center small sortable" onclick="sort('-')">
                Created At
            </th>
            <th class="text-center small sortable" onclick="sort('inTransit')">
                Shipped At
            <th class="text-center small">
                Grand Amount
            </th>
                
        </tr>
    </thead>

    <tbody id="inTransitTableBody">
        <!-- injected by JS -->
    </tbody>
</table>


<nav aria-label="In Transit Transaction Pagination" class="mt-3">
    <ul id="pagination" class="pagination justify-content-center">
        <!-- pagination injected by JS -->
    </ul>
</nav>


<script src="~/js/transaction-inTransit.js"></script>



