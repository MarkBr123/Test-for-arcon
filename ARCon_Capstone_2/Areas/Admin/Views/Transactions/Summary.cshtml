@{
    ViewData["Title"] = "Transaction Summary";
}
<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">Transaction Summary</h4>

        <button class="btn btn-outline-secondary"
                onclick="location.href='/Admin/Transactions/Index'">
            ← Go Back
        </button>
    </div>


    <!--  TRANSACTION INFORMATION -->

    <div class="card mb-4">
        <div class="card-header fw-semibold">
            Transaction Information
        </div>
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-md-3 fw-semibold">Transaction Code</div>
                <div class="col-md-9 fw-bold fs-2 text-primary" id="summaryTransactionCode"></div>
            </div>
            <div class="row mb-2">
                <div class="col-md-3 fw-semibold">Placed At</div>
                <div class="col-md-9" id="summaryCreatedAt"></div>
            </div>
            <div class="row">
                <div class="col-md-3 fw-semibold">Status</div>
                <div class="col-md-9" id="summaryStatus"></div>
            </div>
        </div>
    </div>


    <!--  CUSTOMER INFORMATION -->

    <div class="card mb-4">
        <div class="card-header fw-semibold">
            Customer Information
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 fw-semibold">Customer Name</div>
                <div class="col-md-9" id="summaryCustomerName"></div>
                <div class="col-md-3 fw-semibold">Customer Contact Number</div>
                <div class="col-md-9" id="summaryCustomerContactNumber"></div>
                <div class="col-md-3 fw-semibold">Delivery Address</div>
                <div class="col-md-9" id="summaryCustomerDelAddress"></div>
            </div>
        </div>
    </div>


    <!--  PAYMENT INFORMATION -->

    <div class="card mb-4">
        <div class="card-header fw-semibold">
            Payment Information
        </div>
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-md-3 fw-semibold">Payment Method</div>
                <div class="col-md-9" id="summaryPaymentMethod"></div>
            </div>
            <div class="row">
                <div class="col-md-3 fw-semibold">Payment Status</div>
                <div class="col-md-9" id="summaryPaymentStatus"></div>
            </div>
        </div>
    </div>


    <!-- 4️ ORDER ITEMS -->

    <div class="card mb-4">
        <div class="card-header fw-semibold">
            Ordered Items
        </div>
        <div class="card-body p-0">
            <table class="table table-bordered align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th class="text-center">Qty</th>
                        <th class="text-end">Product Price</th>
                        <th class="text-end">Std Install</th>
                        <th class="text-end">Add Install</th>
                        <th class="text-end">Total</th>
                    </tr>
                </thead>
                <tbody id="summaryItemsTableBody">
                    <!-- Injected by JS -->
                </tbody>
            </table>
        </div>
    </div>


    <!-- FINANCIAL SUMMARY -->

    <div class="card">
        <div class="card-header fw-semibold">
            Financial Summary
        </div>
        <div class="card-body">

            <div class="d-flex justify-content-between mb-2">
                <span>Delivery Cost</span>
                <span id="summaryDeliveryCost"></span>
            </div>

            <hr />

            <div class="d-flex justify-content-between fs-5 fw-bold">
                <span>Grand Total</span>
                <span id="summaryGrandTotal"></span>
            </div>

        </div>
    </div>
    <div class="mt-4 d-flex justify-content-end gap-2">

        <button id="confirmBtn"
                class="btn btn-success"
                onclick="confirmOrder(@ViewBag.TransactionId)">
            Confirm Order
        </button>

        <button id="rejectBtn"
                class="btn btn-danger"
                onclick="rejectOrder(@ViewBag.TransactionId)">
            Reject Order
        </button>

    </div>

</div>



<!--Confirmation Modal-->
<div class="modal fade" id="finalConfirmModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Final Confirmation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p id="confirmMessage"></p>
                <small class="text-danger">
                    Please wait 3 seconds before confirming.
                </small>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="button"
                        id="finalConfirmBtn"
                        class="btn btn-danger"
                        disabled>
                    Yes, Proceed
                </button>
            </div>

        </div>
    </div>
</div>






<script src="~/js/transaction-summary.js"></script>
