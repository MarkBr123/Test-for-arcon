@page
@model ARCon_Capstone_2.Areas.Ecommerce.Views.Home.SigninModel

@section Styles {
    <link rel="stylesheet" href="~/css/Login.css" asp-append-version="true" />
}

<div class="signup-page">
    <div class="signup-card">

        <!-- Left column: Signup form -->
        <div class="signup-form">
            <h2>Sign Up</h2>
            <p class="subtitle">Welcome to our website, let’s get started</p>

            <form method="post">

                <h6>Name</h6>
                <input type="text" placeholder="Username" required />
                <div class="name-row">
                    <input id="fname" type="text" placeholder="First name" />
                    <input id="lname" type="text" placeholder="Last name" />
                    <input id="mname" type="text" placeholder="Middle name" />
                </div>

                <h6>Address</h6>
                <input id="address" type="text" placeholder="Street Address" />
                <input id="caddress" type="text" placeholder="Street Address Line 2" />

                <div class="name-row">
                    <input id="Barangay" type="text" placeholder="Barangay" />
                    <input id="city" type="text" placeholder="City" />
                </div>
                <div class="name-row">
                    <input id="posta" type="text" placeholder="Postal/Zip Code" />
                    <select id="country" required>
                        <option value="">Country</option>
                        <option value="PH">Philippines</option>
                    </select>
                </div>

            </form>
        </div>

        <!-- Right column: Info and illustration -->
        <div class="signup-right">
            <div class="signup-form-right">

                <form method="post">
                    <h6>Contact</h6>
                    <input id="email" type="email" placeholder="Email" required />
                    <input id="contact" type="text" placeholder="Contact number" required />

                    <h6>Password</h6>
                    <input id="password" type="password" placeholder="Password" required />
                    <input id="cpassword" type="password" placeholder="Confirm Password" required />

                    <button type="submit">Create Account</button>
                </form>
            </div>
            <div class="illustration">
                @* <h3>Aircon-i</h3>
                <p>Welcome</p> *@
                <img src="~/ImageSources/Background/repair.jpg" alt="Illustration" />
            </div>
        </div>

    </div>
</div>

