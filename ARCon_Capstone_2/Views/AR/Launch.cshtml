@{
    Layout = null;
    var sku = ViewBag.SKU;
    var productName = ViewBag.ProductName;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    <title>Launching AR - @productName</title>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/4.0.0/model-viewer.min.js"></script>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        model-viewer {
            width: 100%;
            height: 100vh;
            background: #111;
        }

        .message {
            position: fixed;
            bottom: 30px;
            left: 0;
            right: 0;
            text-align: center;
            color: white;
            background: rgba(0,0,0,0.7);
            padding: 12px;
            z-index: 100;
            font-size: 14px;
        }

        .loading {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            background: rgba(0,0,0,0.8);
            padding: 16px 24px;
            border-radius: 40px;
            z-index: 200;
        }
    </style>
</head>
<body>
    <div class="loading" id="loading">Loading AR experience...</div>

    <model-viewer id="viewer"
                  src=""
                  ar
                  ar-modes="scene-viewer webxr quick-look"
                  camera-controls
                  auto-rotate
                  ar-placement="floor">
    </model-viewer>

    <div class="message">
        🚀 AR is launching automatically...
    </div>

    <script>
        const models = {
            "LGC-SPL00001": "lg_dual_inverter_premium.glb",
            "CAR-SPL00001": "carrier_aura_inverter_1-1.5hp.glb",
            "KOP-SPL00001": "Koppel_Lunaire_Inverter_1HP.glb",
            "PAN-SPL00001": "panasonic_premium_inverter_xu_series_1-1.5hp.glb"
        };

        const sku = "@sku";
        const filename = models[sku] || "lg_dual_inverter_premium.glb";
        const modelUrl = "/models/" + filename;

        const viewer = document.getElementById('viewer');
        viewer.src = modelUrl;

        // AUTO-LAUNCH AR when model is ready
        viewer.addEventListener('load', () => {
            document.getElementById('loading').style.display = 'none';

            // Auto-activate AR after 1 second
            setTimeout(() => {
                if (viewer.activateAR) {
                    viewer.activateAR();
                }
            }, 1000);
        });

        // Fallback for iOS - redirect to USDZ
        const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
        if (isIOS) {
            const iosUrl = modelUrl.replace('.glb', '.usdz');
            setTimeout(() => {
                window.location.href = iosUrl;
            }, 500);
        }
    </script>
</body>
</html>