@{
    Layout = null;
    var productModel = ViewBag.ProductModel;
    var productName = ViewBag.ProductName;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    <title>AR - @productName</title>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/4.0.0/model-viewer.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <style>
        body {
            margin: 0;
            overflow: hidden;
        }

        model-viewer {
            width: 100%;
            height: 100vh;
            background: #111;
        }

        .status {
            position: fixed;
            bottom: 30px;
            left: 0;
            right: 0;
            text-align: center;
            color: white;
            background: rgba(0,0,0,0.8);
            padding: 12px;
            z-index: 100;
            font-size: 14px;
        }

        .loading {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            background: rgba(0,0,0,0.9);
            padding: 16px 24px;
            border-radius: 40px;
            z-index: 200;
            font-size: 16px;
        }

        .ar-button {
            position: fixed !important;
            bottom: 30px !important;
            left: 50% !important;
            transform: translateX(-50%) !important;
            background: #007aff !important;
            color: white !important;
            border: none !important;
            border-radius: 50px !important;
            padding: 15px 30px !important;
            font-size: 18px !important;
            font-weight: bold !important;
            cursor: pointer !important;
            z-index: 100 !important;
        }

        /* QR CODE - DESKTOP ONLY */
        .qr-wrapper {
            position: fixed;
            top: 50%;
            right: 40px;
            transform: translateY(-50%);
            z-index: 100;
            background: white;
            padding: 20px;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            text-align: center;
        }

        #qrcode img, #qrcode canvas {
            width: 280px !important;
            height: 280px !important;
        }

        .qr-label {
            margin-top: 12px;
            font-size: 14px;
            color: #333;
            font-weight: 500;
        }

        .model-label {
            margin-top: 8px;
            font-size: 12px;
            color: #666;
        }

        /* HIDE QR ON MOBILE */
        @@media (max-width: 768px) {
            .qr-wrapper {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="loading" id="loading">Loading 3D Model...</div>
    <div class="status" id="status">Preparing AR experience...</div>

    <!-- QR CODE - DESKTOP ONLY -->
    <div class="qr-wrapper">
        <div id="qrcode"></div>
        <div class="qr-label">📱 SCAN WITH PHONE</div>
        <div class="model-label">@productModel</div>
    </div>

    <model-viewer id="viewer"
                  src=""
                  ar
                  ar-modes="scene-viewer webxr quick-look"
                  camera-controls
                  auto-rotate
                  shadow-intensity="1">
        <button slot="ar-button" class="ar-button">
            📱 VIEW IN AR
        </button>
    </model-viewer>

    <script>
        // Use Product Model instead of SKU
        const productModel = "@productModel";

        // Clean the product model name for URL (remove special characters, replace spaces with %20)
        const encodedModel = encodeURIComponent(productModel);
        const modelUrl = "https://raw.githubusercontent.com/MarkBr123/ar-models/main/" + encodedModel + ".glb";

        const viewer = document.getElementById('viewer');
        const loadingDiv = document.getElementById('loading');
        const statusDiv = document.getElementById('status');

        console.log("Product Model:", productModel);
        console.log("Loading model from:", modelUrl);
        viewer.src = modelUrl;

        // Generate QR code for desktop
        const qrDiv = document.getElementById('qrcode');
        if (qrDiv && window.innerWidth > 768) {
            new QRCode(qrDiv, {
                text: window.location.href,
                width: 280,
                height: 280
            });
        }

        // Check if mobile device
        const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);

        viewer.addEventListener('load', () => {
            loadingDiv.style.display = 'none';
            statusDiv.textContent = '✓ Model ready - Launching AR...';
            statusDiv.style.background = 'rgba(0,128,0,0.8)';

            // AUTO-LAUNCH AR ON MOBILE
            if (isMobile) {
                setTimeout(() => {
                    if (viewer.activateAR) {
                        viewer.activateAR();
                    } else {
                        statusDiv.textContent = '✓ Tap AR button to view in space';
                    }
                }, 1500);
            } else {
                statusDiv.textContent = '✓ Model ready - Scan QR on your phone';
            }
        });

        viewer.addEventListener('error', (e) => {
            loadingDiv.innerHTML = '❌ Model not found: ' + productModel + '.glb';
            statusDiv.innerHTML = 'Make sure file exists: ' + productModel + '.glb';
            statusDiv.style.background = 'rgba(255,0,0,0.8)';
        });
    </script>
</body>
</html>