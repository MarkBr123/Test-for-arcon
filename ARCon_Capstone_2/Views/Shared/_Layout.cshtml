<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Airconi Aircon Trading</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ARCon_Capstone_2.styles.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body>

    <!-- ==============================
         NAVBAR
    ============================== -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">ARCon_Capstone_2</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ==============================
         MAIN CONTENT
    ============================== -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- ==============================
         FLOATING CHAT BUTTON
    ============================== -->
    <div id="chatFloatingBtn">💬</div>

    <!-- ==============================
         CHAT SIDEBAR
    ============================== -->
    <div id="chatSidebar" class="chat-sidebar">

        <!-- HEADER -->
        <div class="chat-header">
            <div>
                <strong>Customer Support</strong><br />
                <small>We’re here to help</small>
            </div>
            <span onclick="closeChatSidebar()" style="cursor:pointer;">✕</span>
        </div>

        <!-- BODY -->
        <div class="chat-body" id="chatMessages">

            <!-- SAMPLE RECEIVED -->
            <div class="chat-row received">
                <div class="chat-bubble">
                    Hello! How can we help you today?
                    <div class="chat-time">10:30 AM</div>
                </div>
            </div>

            <!-- SAMPLE SENT -->
            <div class="chat-row sent">
                <div class="chat-bubble">
                    I need help with my order.
                    <div class="chat-time">10:31 AM</div>
                </div>
            </div>

        </div>

        <!-- FOOTER -->
        <div class="chat-footer">
            <input type="text" id="chatInput" placeholder="Type a message..." />
            <button onclick="sendCustomerMessage()">Send</button>
        </div>

    </div>

    <!-- ==============================
         FOOTER
    ============================== -->
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - ARCon_Capstone_2 -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <!-- ==============================
         SCRIPTS
    ============================== -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>